---
import { SITE, CONTACT, SOCIAL, WA_MESSAGES } from '../config/site';
import { waUrl, telUrl } from '../lib/utils';

const productLinks = [
  { label: 'Mini Castillo', href: '/inflables-chicos/mini-castillo' },
  { label: 'Dragones Rojos', href: '/inflables-medianos/dragones-rojos' },
  { label: 'Mini Jungla', href: '/inflables-medianos/mini-jungla' },
  { label: 'Gusanitos', href: '/inflables-medianos/gusanitos' },
  { label: 'Castillo de Princesas', href: '/inflables-medianos/castillo-de-princesas' },
  { label: 'Barco Pirata', href: '/inflables-grandes/barco-pirata' },
  { label: 'Circuito Extremo', href: '/inflables-grandes/extremo' },
  { label: 'Castillo Blanco', href: '/inflables-grandes/castillo-blanco' },
];

const empresaLinks = [
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Cobertura', href: '/#cobertura' },
  { label: 'FAQ', href: '/#faq' },
];
---

<footer class="footer">
  <!-- Top accent bar -->
  <div class="footer__accent" aria-hidden="true"></div>

  <!-- CTA band -->
  <div class="footer__cta-band">
    <div class="footer__cta-inner">
      <div class="footer__cta-text">
        <p class="footer__cta-heading">¿Aún tienes dudas?</p>
        <p class="footer__cta-sub">Contáctanos por WhatsApp o por teléfono. Respondemos rápido.</p>
      </div>
      <div class="footer__cta-actions">
        <a
          href={waUrl(WA_MESSAGES.cotizar)}
          target="_blank"
          rel="noopener"
          class="footer__btn-wa"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          WhatsApp
        </a>
        <a href={telUrl()} class="footer__btn-tel">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.12 6.12l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Llamar
        </a>
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="footer__body">
    <div class="footer__body-inner">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href="/" class="footer__logo" aria-label={SITE.brand}>{SITE.brand}</a>
        <p class="footer__brand-desc">
          Renta de inflables para fiestas en CDMX y Estado de México. 30 años llevando alegría a las familias.
        </p>
        <ul class="footer__contact-list">
          <li>
            <a href={telUrl()} class="footer__contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.12 6.12l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {CONTACT.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={waUrl(WA_MESSAGES.info)} target="_blank" rel="noopener" class="footer__contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${CONTACT.email}`} class="footer__contact-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {CONTACT.email}
            </a>
          </li>
        </ul>
      </div>

      <!-- Catalogo column -->
      <div class="footer__nav-col">
        <h3 class="footer__nav-title">Catálogo</h3>
        <ul class="footer__nav-list">
          {productLinks.map((link) => (
            <li><a href={link.href} class="footer__nav-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Empresa column -->
      <div class="footer__nav-col">
        <h3 class="footer__nav-title">Empresa</h3>
        <ul class="footer__nav-list">
          {empresaLinks.map((link) => (
            <li><a href={link.href} class="footer__nav-link">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contacto column -->
      <div class="footer__nav-col">
        <h3 class="footer__nav-title">Contacto</h3>
        <ul class="footer__nav-list">
          <li><a href={telUrl()} class="footer__nav-link">{CONTACT.phoneDisplay}</a></li>
          <li>
            <a href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener" class="footer__nav-link">
              WhatsApp
            </a>
          </li>
          <li><a href={`mailto:${CONTACT.email}`} class="footer__nav-link">{CONTACT.email}</a></li>
          <li class="footer__nav-schedule">{CONTACT.schedule.display}</li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <p class="footer__copy">
        © <span id="footer-year"></span> {SITE.brand} · Todos los derechos reservados
      </p>
      <ul class="footer__legal">
        <li><a href="/aviso-de-privacidad" class="footer__legal-link">Aviso de Privacidad</a></li>
        <li><a href="/terminos" class="footer__legal-link">Términos</a></li>
      </ul>
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>

<style>
  .footer {
    background: #0d0d0d;
  }

  /* ── Top accent bar ── */
  .footer__accent {
    height: 3px;
    background: linear-gradient(90deg, var(--c-primary) 0%, var(--c-primary-light) 100%);
  }

  /* ── CTA band ── */
  .footer__cta-band {
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: var(--sp-8);
  }

  .footer__cta-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
  }

  .footer__cta-heading {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 var(--sp-1);
  }

  .footer__cta-sub {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 0;
  }

  .footer__cta-actions {
    display: flex;
    gap: var(--sp-3);
    flex-shrink: 0;
  }

  .footer__btn-wa {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--c-wa);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 600;
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .footer__btn-wa:hover {
    background: #20ba58;
  }

  .footer__btn-tel {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    padding: var(--sp-2) var(--sp-5);
    border-radius: var(--radius-full);
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .footer__btn-tel:hover {
    border-color: rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  /* ── Body ── */
  .footer__body {
    padding-block: var(--sp-12);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer__body-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
  }

  @media (min-width: 640px) {
    .footer__body-inner {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__body-inner {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  /* ── Brand column ── */
  .footer__logo {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
    text-decoration: none;
    margin-bottom: var(--sp-4);
    letter-spacing: -0.02em;
  }

  .footer__brand-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: var(--sp-5);
  }

  .footer__contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .footer__contact-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__contact-link:hover {
    color: #fff;
  }

  /* ── Nav columns ── */
  .footer__nav-title {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: var(--sp-4);
  }

  .footer__nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .footer__nav-link {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.55);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__nav-link:hover {
    color: #fff;
  }

  .footer__nav-schedule {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.35);
    margin-top: var(--sp-2);
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    padding-block: var(--sp-5);
  }

  .footer__bottom-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
  }

  .footer__copy {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin: 0;
  }

  .footer__legal {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--sp-4);
  }

  .footer__legal-link {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer__legal-link:hover {
    color: rgba(255, 255, 255, 0.7);
  }
</style>
