---
import { SITE, WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';

const navLinks = [
  { label: 'Inicio', href: '/' },
  {
    label: 'Catálogo',
    href: '/catalogo',
    children: [
      { label: 'Ver todos', href: '/catalogo' },
      { label: 'Inflables chicos', href: '/inflables-chicos', desc: 'Para bebés 1–3 años' },
      { label: 'Inflables medianos', href: '/inflables-medianos', desc: 'Para 3–10 años' },
      { label: 'Inflables grandes', href: '/inflables-grandes', desc: 'Para 5–15 años' },
    ],
  },
  { label: 'Cobertura', href: '/#cobertura' },
  { label: 'FAQ', href: '/#faq' },
  { label: 'Artículos', href: '/articulos' },
  { label: 'Nosotros', href: '/nosotros' },
  { label: 'Contacto', href: '/contacto' },
];

const currentPath = Astro.url.pathname;
---
<header class="site-header" id="site-header">
  <div class="hdr-inner container">
    <a href="/" class="hdr-logo" aria-label={`${SITE.brand} - Inicio`}>
      <img
        src="/img/logo-inflapy.png"
        alt={SITE.brand}
        class="hdr-logo__img"
        width="217"
        height="50"
        loading="eager"
        decoding="async"
      />
    </a>

    <nav class="hdr-nav" aria-label="Navegación principal">
      <ul class="hdr-nav__list" role="list">
        {navLinks.map((link) => (
          <li class="hdr-nav__item" class:list={[link.children ? 'has-dropdown' : '']}>
            {link.children ? (
              <button
                class:list={['hdr-nav__link', currentPath.startsWith(link.href) && 'hdr-nav__link--active']}
                aria-expanded="false"
                aria-haspopup="true"
                data-dropdown-trigger
              >
                {link.label}
                <svg class="hdr-chevron" viewBox="0 0 16 16" fill="currentColor" width="12" height="12" aria-hidden="true">
                  <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round"/>
                </svg>
              </button>
              <div class="drop-panel" role="menu" id={`navp-${link.label.toLowerCase()}`}>
                <div class="drop-panel__inner">
                  <a class="drop-panel__header" href={link.href} role="menuitem">
                    Ver todos los {link.label.toLowerCase()}
                  </a>
                  {link.children.slice(1).map((child) => (
                    <a class="drop-panel__link" href={child.href} role="menuitem">
                      <span class="drop-panel__link-label">{child.label}</span>
                      {child.desc && <span class="drop-panel__link-desc">{child.desc}</span>}
                    </a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                class:list={['hdr-nav__link', (currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href))) && 'hdr-nav__link--active']}
                href={link.href}
              >
                {link.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <a href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener" class="hdr-cta btn btn-primary">
      <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.789l4.89-1.56A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.487 0-4.784-.805-6.659-2.168l-.478-.357-2.953.943.894-2.906-.386-.499A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
      </svg>
      Cotizar
    </a>

    <button class="hdr-burger" aria-label="Menú" aria-expanded="false" aria-controls="mobile-nav" id="burger-btn">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile nav -->
  <nav class="hdr-mobile-nav" id="mobile-nav" aria-hidden="true" aria-label="Menú móvil">
    <div class="mob-scroll">
      <a href="/" class="mob-direct">Inicio</a>
      <div class="mob-item">
        <button class="mob-item__trigger" aria-expanded="false" data-mob-trigger>
          Catálogo
          <svg class="mob-chevron" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" width="16" height="16" aria-hidden="true">
            <path d="M4 6l4 4 4-4" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="mob-item__panel" aria-hidden="true">
          <div class="mob-item__panel-inner">
            <a href="/catalogo" class="mob-item__all">Ver todos →</a>
            <a href="/inflables-chicos" class="mob-item__link">Inflables chicos (bebés)</a>
            <a href="/inflables-medianos" class="mob-item__link">Inflables medianos</a>
            <a href="/inflables-grandes" class="mob-item__link">Inflables grandes</a>
          </div>
        </div>
      </div>
      <a href="/#cobertura" class="mob-direct">Cobertura</a>
      <a href="/#faq" class="mob-direct">Preguntas frecuentes</a>
      <a href="/articulos" class="mob-direct">Artículos</a>
      <a href="/nosotros" class="mob-direct">Nosotros</a>
      <a href="/contacto" class="mob-direct">Contacto</a>
    </div>
    <div class="mob-foot">
      <div class="mob-foot__cta">
        <a href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener" class="mob-cta">
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.789l4.89-1.56A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.487 0-4.784-.805-6.659-2.168l-.478-.357-2.953.943.894-2.906-.386-.499A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
          </svg>
          Cotizar por WhatsApp
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
.site-header {
  position: sticky;
  top: var(--topbar-height);
  z-index: 500;
  background: var(--c-white);
  border-bottom: 1px solid var(--c-border);
  box-shadow: var(--shadow-sm);
  transition: box-shadow var(--transition);
}
.site-header.is-scrolled { box-shadow: 0 2px 10px rgba(0,0,0,.1), 0 10px 28px rgba(0,0,0,.07); }
.hdr-inner {
  display: flex;
  align-items: center;
  gap: var(--sp-6);
  height: var(--header-height);
}
.hdr-logo {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  text-decoration: none;
}
.hdr-logo__img {
  height: 50px;
  width: auto;
  display: block;
  object-fit: contain;
}
@media (max-width: 1024px) {
  .hdr-logo__img { height: 44px; }
}
@media (max-width: 640px) {
  .hdr-logo__img { height: 38px; }
}

.hdr-nav { margin-left: auto; }
.hdr-nav__list {
  display: flex;
  align-items: center;
  gap: var(--sp-1);
  list-style: none;
  margin: 0;
  padding: 0;
}
.hdr-nav__item { position: relative; }
.hdr-nav__item.has-dropdown { padding-bottom: 8px; margin-bottom: -8px; }
.hdr-nav__link {
  position: relative;
  display: flex;
  align-items: center;
  gap: 4px;
  padding: var(--sp-2) var(--sp-3);
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  color: var(--c-ink-2);
  border-radius: var(--radius-md);
  white-space: nowrap;
  text-decoration: none;
  background: none;
  border: none;
  cursor: pointer;
  transition: color .15s, background .15s;
}
.hdr-nav__link:hover { color: var(--c-primary); background: rgba(var(--c-primary-rgb), .08); }
.hdr-nav__link--active {
  color: var(--c-primary);
  background: rgba(var(--c-primary-rgb), .08);
  font-weight: var(--weight-semibold);
}
.hdr-chevron { opacity: .55; transition: transform .2s; }
.has-dropdown:hover .hdr-chevron { transform: rotate(180deg); }

.drop-panel {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-lg);
  box-shadow: 0 14px 34px rgba(0,0,0,.14), 0 2px 8px rgba(0,0,0,.06);
  min-width: 240px;
  opacity: 0;
  transform: translateY(-6px);
  pointer-events: none;
  transition: opacity .16s, transform .16s;
  z-index: 490;
}
.hdr-nav__item.has-dropdown:hover .drop-panel { opacity: 1; transform: translateY(0); pointer-events: all; }
.drop-panel__inner { padding: .5rem .375rem; display: flex; flex-direction: column; }
.drop-panel__header {
  display: block;
  padding: .5rem .75rem;
  font-size: var(--text-xs);
  font-weight: var(--weight-bold);
  color: var(--c-primary);
  text-decoration: none;
  border-bottom: 1px solid var(--c-border);
  margin-bottom: .25rem;
  text-transform: uppercase;
  letter-spacing: .06em;
}
.drop-panel__link {
  display: flex;
  flex-direction: column;
  gap: .125rem;
  padding: .55rem .75rem;
  font-size: var(--text-sm);
  color: var(--c-ink-2);
  border-radius: 7px;
  text-decoration: none;
  transition: color .15s, background .15s;
}
.drop-panel__link:hover { background: rgba(var(--c-primary-rgb), .08); color: var(--c-primary); }
.drop-panel__link-label { font-weight: var(--weight-semibold); }
.drop-panel__link-desc { font-size: var(--text-xs); color: var(--c-muted); }

.hdr-cta { margin-left: var(--sp-3); flex-shrink: 0; }

.hdr-burger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  padding: 0;
  margin-left: auto;
  cursor: pointer;
  border: 1px solid var(--c-border);
  background: var(--c-white);
  border-radius: var(--radius-md);
  width: 44px;
  height: 44px;
  transition: border-color .15s;
}
.hdr-burger:hover { border-color: var(--c-primary); }
.hdr-burger span {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--c-ink-2);
  border-radius: 2px;
  transition: transform .25s, opacity .2s;
}
.hdr-burger[aria-expanded="true"] span { background: var(--c-primary); }
.hdr-burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.hdr-burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.hdr-burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* Mobile nav */
.hdr-mobile-nav {
  position: fixed;
  top: var(--stack-height);
  left: 0; right: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  background: var(--c-white);
  z-index: 490;
  border-top: 1px solid var(--c-border);
  opacity: 0;
  transform: translateY(-10px);
  pointer-events: none;
  transition: opacity .22s, transform .22s;
}
.hdr-mobile-nav[aria-hidden="false"] { opacity: 1; transform: translateY(0); pointer-events: all; }
.mob-scroll { flex: 1 1 auto; overflow-y: auto; overscroll-behavior: contain; padding: .25rem 0 .5rem; }
.mob-item { border-bottom: 1px solid var(--c-border); }
.mob-item__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: .75rem;
  padding: 1rem 1.25rem;
  min-height: 56px;
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: var(--weight-semibold);
  color: var(--c-ink);
  background: none;
  border: none;
  cursor: pointer;
  transition: color .15s, background .15s;
}
.mob-item__trigger[aria-expanded="true"] {
  color: var(--c-primary);
  background: rgba(var(--c-primary-rgb), .05);
  box-shadow: inset 3px 0 0 var(--c-primary);
}
.mob-chevron { flex-shrink: 0; opacity: .6; transition: transform .25s; }
.mob-item__trigger[aria-expanded="true"] .mob-chevron { transform: rotate(180deg); }
.mob-item__panel { overflow: hidden; max-height: 0; transition: max-height .3s; }
.mob-item__panel.is-open { max-height: 400px; }
.mob-item__panel-inner {
  padding: .35rem 1.25rem 1rem;
  background: var(--c-surface);
  display: flex;
  flex-direction: column;
  gap: .125rem;
}
.mob-item__all {
  display: inline-flex;
  align-items: center;
  align-self: flex-start;
  padding: .45rem .7rem;
  font-size: .8125rem;
  font-weight: var(--weight-bold);
  color: var(--c-primary);
  text-decoration: none;
  border-radius: 7px;
  margin-bottom: .25rem;
}
.mob-item__link {
  display: flex;
  align-items: center;
  min-height: 44px;
  padding: .5rem .7rem;
  font-size: .9875rem;
  color: var(--c-ink-2);
  text-decoration: none;
  border-radius: 7px;
  transition: background .15s, color .15s;
}
.mob-item__link:hover { background: rgba(var(--c-primary-rgb), .1); color: var(--c-primary); }
.mob-direct {
  display: flex;
  align-items: center;
  min-height: 56px;
  padding: 1rem 1.25rem;
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: var(--weight-semibold);
  color: var(--c-ink);
  border-bottom: 1px solid var(--c-border);
  text-decoration: none;
  transition: color .15s, background .15s;
}
.mob-direct:hover { color: var(--c-primary); background: rgba(var(--c-primary-rgb), .05); box-shadow: inset 3px 0 0 var(--c-primary); }
.mob-foot {
  flex: 0 0 auto;
  border-top: 1px solid var(--c-border);
  background: var(--c-white);
  padding: .9rem 1.25rem calc(.9rem + env(safe-area-inset-bottom, 0px));
}
.mob-foot__cta { display: flex; gap: .6rem; }
.mob-cta {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: .45rem;
  min-height: 50px;
  border-radius: var(--radius-md);
  font-family: var(--font-heading);
  font-weight: var(--weight-bold);
  font-size: .98rem;
  text-decoration: none;
  background: var(--c-primary);
  color: #fff;
  box-shadow: 0 4px 12px rgba(var(--c-primary-rgb), .32);
}
.mob-cta:hover { background: var(--c-primary-dark); }

@media (max-width: 1024px) {
  .hdr-nav, .hdr-cta { display: none; }
  .hdr-burger { display: flex; }
}
</style>

<script>
const burger = document.getElementById('burger-btn') as HTMLButtonElement;
const mobileNav = document.getElementById('mobile-nav') as HTMLElement;
const header = document.getElementById('site-header') as HTMLElement;

// Burger toggle
burger?.addEventListener('click', () => {
  const isOpen = burger.getAttribute('aria-expanded') === 'true';
  burger.setAttribute('aria-expanded', String(!isOpen));
  mobileNav.setAttribute('aria-hidden', String(isOpen));
  document.body.classList.toggle('menu-open', !isOpen);
});

// Mobile accordion
document.querySelectorAll('[data-mob-trigger]').forEach((btn) => {
  btn.addEventListener('click', () => {
    const isOpen = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!isOpen));
    const panel = btn.nextElementSibling as HTMLElement;
    panel?.classList.toggle('is-open', !isOpen);
    panel?.setAttribute('aria-hidden', String(isOpen));
  });
});

// Header scroll shadow
window.addEventListener('scroll', () => {
  header?.classList.toggle('is-scrolled', window.scrollY > 40);
}, { passive: true });

// Close menu on link click
mobileNav?.querySelectorAll('a').forEach((a) => {
  a.addEventListener('click', () => {
    burger?.setAttribute('aria-expanded', 'false');
    mobileNav.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('menu-open');
  });
});
</script>
