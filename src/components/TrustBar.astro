---
const items = [
  {
    label: '30 Años de experiencia',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  },
  {
    label: '10,000+ Eventos realizados',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    label: 'Instalación incluida',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`,
  },
  {
    label: 'CDMX y Estado de México',
    icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  },
];
---

<div class="trust-bar">
  <div class="trust-bar__inner">
    {items.map((item) => (
      <div class="trust-bar__item">
        <span class="trust-bar__icon" set:html={item.icon} />
        <span class="trust-bar__label">{item.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .trust-bar {
    background: var(--c-ink);
    padding-block: var(--sp-4);
  }

  .trust-bar__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-4) var(--sp-8);
  }

  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    white-space: nowrap;
  }

  .trust-bar__icon {
    color: var(--c-primary);
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .trust-bar__label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
  }

  @media (max-width: 639px) {
    .trust-bar__inner {
      gap: var(--sp-3) var(--sp-6);
    }

    .trust-bar__label {
      font-size: 0.8rem;
    }
  }
</style>
