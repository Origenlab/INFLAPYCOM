---
import { STATS } from '../config/site';

const icons: Record<number, string> = {
  0: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  1: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  2: `<svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  3: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.42 2 2 0 0 1 3.62 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.97a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`,
};
---

<section class="stats">
  <div class="stats__inner">
    {STATS.map((stat, i) => (
      <div class="stats__item">
        <span class="stats__icon" set:html={icons[i]} />
        <span class="stats__value">{stat.value}</span>
        <span class="stats__label">{stat.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats {
    background: linear-gradient(135deg, #111827 0%, #1f2937 100%);
    padding-block: var(--sp-12);
    border-top: 1px solid rgba(255,255,255,.06);
    border-bottom: 1px solid rgba(255,255,255,.06);
  }

  .stats__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--sp-8) var(--sp-6);
  }

  @media (min-width: 768px) {
    .stats__inner { grid-template-columns: repeat(4, 1fr); gap: var(--sp-6); }
  }

  .stats__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--sp-3);
    padding: var(--sp-5);
    border: 1px solid rgba(255,255,255,.08);
    border-radius: var(--radius-xl);
    background: rgba(255,255,255,.03);
  }

  .stats__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-lg);
    background: rgba(var(--c-primary-rgb), .15);
    color: var(--c-primary);
    flex-shrink: 0;
  }

  .stats__value {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .stats__label {
    font-family: var(--font-body);
    font-size: .875rem;
    color: rgba(255,255,255,.55);
    font-weight: 400;
    line-height: 1.4;
  }
</style>
