---
// Reviews.astro — Sección de testimonios.
// Data-driven desde REVIEWS (site.ts). Usa ReviewCard canónico.
// REGLA: solo reseñas reales (cero aggregateRating fabricado).
import { REVIEWS } from '../config/site';
import SectionHeading from './SectionHeading.astro';
import ReviewCard from './ReviewCard.astro';
---

<section class="reviews" id="testimonios">
  <div class="reviews__inner">
    <SectionHeading
      eyebrow="Reseñas"
      title="Lo que dicen"
      titleAccent="nuestros clientes"
      center={true}
    />

    <div class="reviews__grid">
      {REVIEWS.map((r) => (
        <ReviewCard
          quote={r.text}
          name={r.author}
          role={r.location}
          rating={r.stars}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .reviews {
    background: var(--c-surface);
    padding-block: var(--section-py);
  }

  .reviews__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  .reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
  }

  @media (min-width: 640px) {
    .reviews__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .reviews__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
