---
// CategoryFeature.astro — Spotlight de producto/categoría: 2 columnas.
// Izquierda: eyebrow + título + descripción + bullets (check) + pills + CTA.
// Derecha: galería 3 imágenes (1 grande arriba + 2 pequeñas abajo).
// Canónico (origen EJEMPLOS.mx). Adaptado a la paleta INFLAPY (morado).
// Úsalo para destacar el inflable estrella antes de que el visitante entre a su ficha.

interface Brand {
  name: string;
  note?: string;
}
interface GalleryImage {
  src: string;
  alt: string;
}
interface Feature {
  label: string;
  desc: string;
}
interface Props {
  eyebrow: string;
  title: string;
  titleAccent?: string;
  description: string;
  features: Feature[];
  brands?: Brand[];
  ctaLabel?: string;
  ctaHref?: string;
  /** Abrir CTA en pestaña nueva (WhatsApp / externos) */
  ctaExternal?: boolean;
  /** Imagen grande (principal) */
  imgMain: GalleryImage;
  /** 2 imágenes pequeñas debajo */
  imgA: GalleryImage;
  imgB: GalleryImage;
  /** Fondo alternado: true = surface, false = blanco */
  surface?: boolean;
  /** Galería a la izquierda (default derecha) */
  flip?: boolean;
}

const {
  eyebrow,
  title,
  titleAccent,
  description,
  features,
  brands = [],
  ctaLabel = 'Ver catálogo',
  ctaHref = '/#catalogo',
  ctaExternal = false,
  imgMain,
  imgA,
  imgB,
  surface = false,
  flip = false,
} = Astro.props;
---

<section class:list={['cf', surface && 'cf--surface', flip && 'cf--flip']}>
  <div class="cf__inner">

    <!-- Columna izquierda: contenido -->
    <div class="cf__content">
      <p class="cf__eyebrow">
        <span class="cf__eyebrow-bar" aria-hidden="true"></span>
        {eyebrow}
      </p>

      <h3 class="cf__title">
        {title}
        {titleAccent && <span class="cf__accent"><br />{titleAccent}</span>}
      </h3>

      <p class="cf__desc">{description}</p>

      {features.length > 0 && (
        <ul class="cf__features">
          {features.map((f) => (
            <li class="cf__feature">
              <span class="cf__feature-dot" aria-hidden="true">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </span>
              <span>
                <strong class="cf__feature-label">{f.label}</strong>
                {f.desc && <span class="cf__feature-desc"> — {f.desc}</span>}
              </span>
            </li>
          ))}
        </ul>
      )}

      {brands.length > 0 && (
        <div class="cf__brands">
          <p class="cf__brands-label">Ideal para</p>
          <div class="cf__brands-list">
            {brands.map((b) => (
              <span class="cf__brand">
                {b.name}
                {b.note && <span class="cf__brand-note">{b.note}</span>}
              </span>
            ))}
          </div>
        </div>
      )}

      <a
        href={ctaHref}
        class="cf__cta"
        target={ctaExternal ? '_blank' : undefined}
        rel={ctaExternal ? 'noopener noreferrer' : undefined}
      >
        {ctaLabel}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Columna derecha: galería -->
    <div class="cf__gallery">
      <figure class="cf__img-wrap cf__img-wrap--main">
        <img src={imgMain.src} alt={imgMain.alt} width="800" height="500" loading="lazy" decoding="async" class="cf__img" />
      </figure>
      <div class="cf__img-row">
        <figure class="cf__img-wrap cf__img-wrap--sm">
          <img src={imgA.src} alt={imgA.alt} width="400" height="300" loading="lazy" decoding="async" class="cf__img" />
        </figure>
        <figure class="cf__img-wrap cf__img-wrap--sm">
          <img src={imgB.src} alt={imgB.alt} width="400" height="300" loading="lazy" decoding="async" class="cf__img" />
        </figure>
      </div>
    </div>

  </div>
</section>

<style>
.cf { padding: var(--section-py) 0; background: var(--c-white); }
.cf--surface { background: var(--c-surface); }

.cf__inner {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: clamp(2.5rem, 5vw, 5rem);
  align-items: center;
}
.cf--flip .cf__gallery { order: -1; }

/* ── Contenido ── */
.cf__eyebrow {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  font-size: var(--text-xs); font-weight: var(--weight-bold);
  text-transform: uppercase; letter-spacing: .08em;
  color: var(--c-primary); margin: 0 0 var(--sp-3);
}
.cf__eyebrow-bar { width: 20px; height: 2px; background: currentColor; border-radius: 2px; flex-shrink: 0; }

.cf__title {
  font-family: var(--font-heading);
  font-size: var(--text-fluid-4xl);
  font-weight: var(--weight-black);
  line-height: var(--leading-tight);
  letter-spacing: -.02em;
  color: var(--c-ink);
  margin: 0 0 var(--sp-4);
}
.cf__accent { color: var(--c-primary); }

.cf__desc {
  font-size: var(--text-base); color: var(--c-ink-2);
  line-height: var(--leading-relaxed); margin: 0 0 var(--sp-5); max-width: 52ch;
}

/* Features */
.cf__features { list-style: none; margin: 0 0 var(--sp-5); padding: 0; display: flex; flex-direction: column; gap: var(--sp-3); }
.cf__feature { display: flex; align-items: flex-start; gap: var(--sp-3); font-size: var(--text-sm); color: var(--c-ink-2); line-height: var(--leading-normal); }
.cf__feature-dot {
  flex-shrink: 0; width: 28px; height: 28px;
  display: flex; align-items: center; justify-content: center;
  background: rgba(var(--c-primary-rgb), .10); color: var(--c-primary);
  border-radius: var(--radius-sm); margin-top: .05rem;
}
.cf__feature-label { color: var(--c-ink); font-weight: var(--weight-semibold); }
.cf__feature-desc { color: var(--c-muted); }

/* Pills "ideal para" */
.cf__brands { margin-bottom: var(--sp-6); }
.cf__brands-label { font-size: var(--text-xs); font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: .07em; color: var(--c-muted); margin: 0 0 var(--sp-2); }
.cf__brands-list { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
.cf__brand {
  display: inline-flex; align-items: center; gap: var(--sp-1);
  font-size: var(--text-sm); font-weight: var(--weight-semibold); color: var(--c-ink);
  background: var(--c-white); border: 1.5px solid var(--c-border);
  border-radius: var(--radius-md); padding: .35rem .8rem;
}
.cf--surface .cf__brand { background: var(--c-surface); }
.cf__brand-note { font-size: var(--text-xs); font-weight: var(--weight-regular); color: var(--c-muted); }

/* CTA */
.cf__cta {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  padding: .75rem 1.5rem; background: var(--c-primary); color: #fff;
  font-family: var(--font-heading); font-size: var(--text-base); font-weight: var(--weight-semibold);
  border-radius: var(--radius-md); text-decoration: none;
  transition: background var(--transition), gap var(--transition);
}
.cf__cta:hover { background: var(--c-primary-dark); gap: var(--sp-3); }
.cf__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }

/* ── Galería ── */
.cf__gallery { display: flex; flex-direction: column; gap: var(--sp-3); }
.cf__img-wrap { margin: 0; overflow: hidden; border-radius: var(--radius-lg); background: var(--c-surface); border: 1px solid var(--c-border); }
.cf__img-wrap--main { aspect-ratio: 16 / 10; }
.cf__img-row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-3); }
.cf__img-wrap--sm { aspect-ratio: 4 / 3; }
.cf__img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Responsive ── */
@media (max-width: 900px) {
  .cf__inner { grid-template-columns: 1fr; gap: var(--sp-8); }
  .cf--flip .cf__gallery { order: 0; }
  .cf__desc { max-width: none; }
}
@media (prefers-reduced-motion: reduce) { .cf__cta { transition: none; } }
</style>
