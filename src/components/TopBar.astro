---
import { CONTACT, SITE, WA_MESSAGES } from '../config/site';
import { waUrl, telUrl } from '../lib/utils';
---
<div class="topbar">
  <div class="container">
    <div class="tb-inner">
      <p class="tb-promo">
        <span class="tb-spark" aria-hidden="true"></span>
        <span class="tb-promo__txt">{SITE.tagline}</span>
      </p>
      <div class="tb-actions">
        <a href={telUrl()} class="tb-item tb-phone" aria-label={`Llamar al ${CONTACT.phoneDisplay}`}>
          <svg class="tb-ico" viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true">
            <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
          </svg>
          {CONTACT.phoneDisplay}
        </a>
        <a href={waUrl(WA_MESSAGES.cotizar)} target="_blank" rel="noopener" class="tb-item tb-wa">
          <svg class="tb-ico" viewBox="0 0 24 24" fill="currentColor" width="13" height="13" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.789l4.89-1.56A11.93 11.93 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-2.487 0-4.784-.805-6.659-2.168l-.478-.357-2.953.943.894-2.906-.386-.499A9.96 9.96 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </div>
</div>

<style>
.topbar {
  position: sticky;
  top: 0;
  z-index: 501;
  height: var(--topbar-height);
  display: flex;
  align-items: center;
  font-size: var(--text-sm);
  font-weight: var(--weight-medium);
  background: linear-gradient(100deg, var(--c-primary-dark) 0%, var(--c-primary) 60%, var(--c-primary-light) 140%);
  color: #fff;
  box-shadow: inset 0 -1px rgba(255,255,255,.15);
}
.tb-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-4);
  width: 100%;
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
}
.tb-promo {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  min-width: 0;
  flex: 1;
  margin: 0;
}
.tb-spark {
  flex-shrink: 0;
  width: 8px;
  height: 8px;
  border-radius: 2px;
  background: #fff;
  transform: rotate(45deg);
  box-shadow: 0 0 0 3px rgba(255,255,255,.18);
}
.tb-promo__txt {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  letter-spacing: .005em;
}
.tb-actions {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  flex-shrink: 0;
}
.tb-item {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  color: #fff;
  text-decoration: none;
  white-space: nowrap;
  padding: .25rem .5rem;
  border-radius: var(--radius-sm);
  transition: background .15s ease;
}
.tb-ico { flex-shrink: 0; opacity: .9; }
.tb-phone:hover { background: rgba(255,255,255,.12); }
.tb-wa {
  background: rgba(255,255,255,.16);
  padding: .25rem .8rem;
  border-radius: var(--radius-full);
  font-weight: var(--weight-semibold);
}
.tb-wa:hover { background: rgba(255,255,255,.3); }

@media (max-width: 900px) {
  .tb-promo { display: none; }
  .tb-actions { flex: 1; justify-content: flex-end; }
}
@media (max-width: 640px) {
  .tb-inner { gap: 0; }
  .tb-actions { width: 100%; gap: 0; }
  .tb-phone, .tb-wa {
    flex: 1;
    justify-content: center;
    min-height: var(--topbar-height);
    background: transparent;
    border-radius: 0;
    font-weight: var(--weight-semibold);
  }
  .tb-phone { box-shadow: inset -1px 0 rgba(255,255,255,.22); }
  .tb-phone:hover, .tb-wa:hover { background: rgba(255,255,255,.12); }
}
</style>
