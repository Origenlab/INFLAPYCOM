---
// ProductShowcase.astro — Sección "cada inflable explicado a fondo".
// Filas alternadas imagen ↔ contenido. Datos 100% desde PRODUCTS[].
// WA CTA por producto: waUrl(WA_MESSAGES.reservar(p.name)).
import { PRODUCTS, WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';
import SectionHeading from './SectionHeading.astro';

const checkIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>`;
---

<section class="showcase" id="detalle">
  <div class="showcase__container">

    <SectionHeading
      eyebrow="Conoce cada inflable"
      title="Cada modelo"
      titleAccent="explicado a fondo"
      layout="duo"
      body={[
        'Medidas reales, capacidad de niños y para qué tipo de fiesta encaja mejor. Todo lo que necesitas para elegir sin dudas.',
        '¿Tienes dudas? Escríbenos por WhatsApp — en minutos te decimos cuál es el inflable ideal para tu fecha, espacio y presupuesto.',
      ]}
    />

    <div class="showcase__list">
      {PRODUCTS.map((p, i) => {
        const waMsg = waUrl(WA_MESSAGES.reservar(p.name));
        const isEven = i % 2 === 0;
        return (
          <article class:list={['showcase__row', isEven ? 'showcase__row--a' : 'showcase__row--b']}>

            {/* Imagen */}
            <div class="showcase__media">
              <div class="showcase__img-wrap">
                <span class="showcase__cat-badge">{p.categoryLabel}</span>
                <img
                  class="showcase__img"
                  src={p.images[0]}
                  alt={`Inflable ${p.name} en renta CDMX — ${p.categoryLabel}`}
                  width="640"
                  height="480"
                  loading="lazy"
                  decoding="async"
                  onerror="this.src='/img/placeholder.svg'"
                />
              </div>
              <span class="showcase__dims-badge">{p.categoryLabel} · {p.dimensions}</span>
            </div>

            {/* Contenido */}
            <div class="showcase__content">
              <p class="showcase__dims">{p.dimensions}</p>
              <h3 class="showcase__title">{p.name}</h3>
              <p class="showcase__desc">{p.descLong}</p>

              <ul class="showcase__features" role="list">
                {p.features.map((f) => (
                  <li class="showcase__feature">
                    <span class="showcase__feature-icon" set:html={checkIcon} />
                    <span>{f}</span>
                  </li>
                ))}
              </ul>

              <div class="showcase__cta-row">
                <a
                  href={waMsg}
                  class="showcase__cta-wa"
                  target="_blank"
                  rel="noopener"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                  </svg>
                  Cotizar el {p.name}
                </a>
                <a href={`/${p.slug}`} class="showcase__cta-detail">
                  Ver detalles
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>

              {/* Precio */}
              <div class="showcase__price-box">
                <span class="showcase__price-from">Desde</span>
                <strong class="showcase__price-amount">${p.price.toLocaleString('es-MX')} MXN</strong>
                <span class="showcase__price-note">{p.priceNote}</span>
              </div>
            </div>

          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .showcase {
    padding-block: var(--section-py);
    background: var(--c-white);
  }

  .showcase__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  .showcase__list {
    display: flex;
    flex-direction: column;
    gap: clamp(4rem, 8vw, 6rem);
  }

  /* ── Row base ── */
  .showcase__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .showcase__row {
      grid-template-columns: 1fr 1fr;
      gap: clamp(3rem, 6vw, 5rem);
    }
    /* even rows: imagen izquierda */
    .showcase__row--a .showcase__media { order: 1; }
    .showcase__row--a .showcase__content { order: 2; }
    /* odd rows: imagen derecha */
    .showcase__row--b .showcase__media { order: 2; }
    .showcase__row--b .showcase__content { order: 1; }
  }

  /* ── Imagen ── */
  .showcase__media {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .showcase__img-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    background: var(--c-surface);
    box-shadow: var(--shadow-lg);
  }

  .showcase__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .showcase__cat-badge {
    position: absolute;
    top: var(--sp-4);
    left: var(--sp-4);
    z-index: 2;
    padding: .3rem .8rem;
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: #fff;
    background: var(--c-primary);
    border-radius: var(--radius-full);
  }

  .showcase__dims-badge {
    align-self: flex-start;
    font-size: .75rem;
    color: var(--c-muted);
    font-weight: 500;
    padding: .2rem .6rem;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-full);
  }

  /* ── Contenido ── */
  .showcase__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .showcase__dims {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--c-primary);
    margin: 0;
  }

  .showcase__title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 800;
    color: var(--c-ink);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin: 0 0 calc(-1 * var(--sp-3));
  }

  .showcase__desc {
    font-size: .95rem;
    color: var(--c-ink-2);
    line-height: 1.75;
    margin: 0;
  }

  /* Feature list */
  .showcase__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .showcase__feature {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    font-size: .9rem;
    font-weight: 500;
    color: var(--c-ink);
    line-height: 1.4;
  }

  .showcase__feature-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: rgba(var(--c-primary-rgb), .12);
    color: var(--c-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* CTAs */
  .showcase__cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }

  .showcase__cta-wa {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: var(--sp-3) var(--sp-6);
    background: #25D366;
    color: #fff;
    font-family: var(--font-body);
    font-size: .9rem;
    font-weight: 600;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
    white-space: nowrap;
  }
  .showcase__cta-wa:hover {
    background: #1eb557;
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(37,211,102,.35);
  }

  .showcase__cta-detail {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: .875rem;
    font-weight: 600;
    color: var(--c-ink-2);
    text-decoration: none;
    transition: color var(--transition);
  }
  .showcase__cta-detail:hover { color: var(--c-primary); }

  /* Precio box */
  .showcase__price-box {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-left: 4px solid var(--c-primary);
    border-radius: var(--radius-lg);
  }

  .showcase__price-from {
    font-size: .7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--c-muted);
  }

  .showcase__price-amount {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--c-primary);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .showcase__price-note {
    font-size: .78rem;
    color: var(--c-muted);
  }

  @media (max-width: 767px) {
    .showcase__row--b .showcase__media { order: 1; }
    .showcase__row--b .showcase__content { order: 2; }
    .showcase__cta-row { flex-direction: column; align-items: stretch; }
    .showcase__cta-wa { justify-content: center; }
  }
</style>
