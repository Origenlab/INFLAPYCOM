---
import { WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';

const links = [
  { label: 'Catálogo', href: '/#catalogo' },
  { label: 'Servicios', href: '/#servicios' },
  { label: 'Proceso', href: '/#proceso' },
  { label: 'Reseñas', href: '/#testimonios' },
  { label: 'FAQ', href: '/#faq' },
];
---

<nav class="section-menu" aria-label="Navegación de secciones">
  <div class="section-menu__inner">
    {links.map((link) => (
      <a href={link.href} class="section-menu__btn">{link.label}</a>
    ))}
    <a
      href={waUrl(WA_MESSAGES.cotizar)}
      target="_blank"
      rel="noopener"
      class="section-menu__btn section-menu__btn--wa"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
      WhatsApp
    </a>
  </div>
</nav>

<style>
  .section-menu {
    background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .section-menu__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: flex;
    gap: var(--sp-1);
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-block: var(--sp-2);
  }

  .section-menu__inner::-webkit-scrollbar {
    display: none;
  }

  .section-menu__btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    white-space: nowrap;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--c-ink-2);
    text-decoration: none;
    padding: var(--sp-2) var(--sp-4);
    border-radius: var(--radius-full);
    border: 1px solid transparent;
    transition: var(--transition);
  }

  .section-menu__btn:hover {
    background: rgba(var(--c-primary-rgb), 0.07);
    color: var(--c-primary);
    border-color: rgba(var(--c-primary-rgb), 0.15);
  }

  .section-menu__btn--wa {
    background: var(--c-wa);
    color: #fff;
    font-weight: 600;
    margin-left: auto;
    flex-shrink: 0;
  }

  .section-menu__btn--wa:hover {
    background: #20ba58;
    color: #fff;
    border-color: transparent;
  }
</style>
