---
import { NAV, WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';

// Metadata por sección: emoji, subtítulo y color de pill
const PILL_META: Record<string, { emoji: string; norm: string; color: string; dark?: boolean }> = {
  '/#catalogo':    { emoji: '🎪', norm: 'Ver inflables',       color: '#7830f8' },
  '/#servicios':   { emoji: '✨', norm: '¿Por qué elegirnos?', color: '#f83088' },
  '/#proceso':     { emoji: '📋', norm: 'Así funciona',        color: '#00d8e0', dark: true },
  '/#testimonios': { emoji: '⭐', norm: 'Lo que dicen',        color: '#e0f000', dark: true },
  '/#cobertura':   { emoji: '📍', norm: 'CDMX y EdoMex',       color: '#7830f8' },
  '/#faq':         { emoji: '💬', norm: 'Preguntas',           color: '#f83088' },
};

const ctaHref = waUrl(WA_MESSAGES.cotizar);
const totalCols = NAV.length + 1; // +1 para el CTA de WA
---

<section class="qnav" aria-label="Ir a sección">
  <div class={`qnav__row qnav__row--cols-${totalCols}`} role="list">

    {NAV.map((link) => {
      const meta = PILL_META[link.href];
      const dark = meta?.dark ?? false;
      return (
        <a
          href={link.href}
          class={`qnav__pill ${dark ? 'qnav__pill--dark-text' : ''}`}
          style={`--pill-color: ${meta?.color ?? '#7830f8'}`}
          role="listitem"
        >
          <span class="qnav__label">{link.label}</span>
          {meta?.norm && <span class="qnav__norm">{meta.norm}</span>}
        </a>
      );
    })}

    {/* CTA — WhatsApp */}
    <a
      href={ctaHref}
      class="qnav__pill qnav__pill--wa"
      target="_blank"
      rel="noopener"
      role="listitem"
    >
      <span class="qnav__label">Cotizar</span>
      <span class="qnav__norm">Por WhatsApp</span>
    </a>

  </div>
</section>

<style>
  .qnav {
    width: 100%;
    padding: 0;
    background: #fff;
    border-bottom: 1px solid var(--c-border);
  }

  .qnav__row {
    display: grid;
    width: 100%;
  }

  /* Grid dinámico según número de pills */
  .qnav__row--cols-7  { grid-template-columns: repeat(7, 1fr); }
  .qnav__row--cols-8  { grid-template-columns: repeat(8, 1fr); }

  /* ── Pill base ── */
  .qnav__pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    padding: 1.1rem 0.75rem;
    min-height: 96px;
    text-decoration: none;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--pill-color, #7830f8);
    color: #ffffff;
    transition: filter 0.18s ease, transform 0.18s ease;
    isolation: isolate;
  }

  /* Efecto shimmer en hover */
  .qnav__pill::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0);
    transition: background 0.18s ease;
  }
  .qnav__pill:hover::before {
    background: rgba(255,255,255,0.12);
  }
  .qnav__pill:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
  }

  /* Separadores verticales entre pills */
  .qnav__pill + .qnav__pill {
    border-left: 1px solid rgba(255,255,255,0.15);
  }

  /* Texto oscuro para yellow y cyan */
  .qnav__pill--dark-text {
    color: #001028;
  }
  .qnav__pill--dark-text .qnav__norm {
    color: rgba(0,16,40, 0.65);
  }
  .qnav__pill--dark-text::before {
    /* noop — override si se necesita */
  }
  .qnav__pill--dark-text:hover::before {
    background: rgba(0,0,0,0.06);
  }

  /* WA CTA */
  .qnav__pill--wa {
    --pill-color: #25D366;
    color: #04210f;
    font-weight: 700;
  }
  .qnav__pill--wa .qnav__norm {
    color: rgba(4, 33, 15, 0.7);
  }
  .qnav__pill--wa:hover::before {
    background: rgba(0,0,0,0.06);
  }

  /* Contenido */
  .qnav__emoji {
    font-size: 1.6rem;
    line-height: 1;
    display: block;
    filter: drop-shadow(0 1px 2px rgba(0,0,0,0.18));
  }

  .qnav__label {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.15;
    position: relative;
    z-index: 1;
  }

  .qnav__norm {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    line-height: 1.2;
    position: relative;
    z-index: 1;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .qnav__row {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    .qnav__pill {
      min-height: 88px;
    }
  }

  @media (max-width: 640px) {
    .qnav__row {
      grid-template-columns: repeat(4, 1fr) !important;
    }
    .qnav__pill {
      min-height: 76px;
      padding: 0.75rem 0.4rem;
    }
    .qnav__emoji {
      font-size: 1.35rem;
    }
    .qnav__label {
      font-size: 0.75rem;
    }
    .qnav__norm {
      display: none;
    }
  }

  @media (max-width: 400px) {
    .qnav__row {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .qnav__pill--wa {
      grid-column: 1 / -1;
    }
  }
</style>
