---
import type { Product } from '../config/site';
import { WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';

interface Props {
  product: Product;
  eager?: boolean;
}

const { product: p, eager = false } = Astro.props;
const waHref = waUrl(WA_MESSAGES.reservar(p.name));
---

<article class="pcard">
  <a class="pcard__link" href={`/${p.slug}`} aria-label={`Ver detalles de ${p.name}`}>

    <!-- Imagen -->
    <div class="pcard__media">
      {p.badge && (
        <span class:list={['pcard__badge', p.badgeHot && 'pcard__badge--hot']}>
          {p.badge}
        </span>
      )}
      <img
        class="pcard__img"
        src={p.images[0]}
        alt={`${p.name} — renta de inflable en CDMX · INFLAPY`}
        width="800"
        height="600"
        loading={eager ? 'eager' : 'lazy'}
        decoding={eager ? 'auto' : 'async'}
        fetchpriority={eager ? 'high' : undefined}
        onerror="this.src='/img/placeholder.svg'"
      />
      <span class="pcard__overlay" aria-hidden="true"></span>
    </div>

    <!-- Cuerpo -->
    <div class="pcard__body">
      <div class="pcard__meta">
        <span class="pcard__category">{p.categoryLabel}</span>
      </div>

      <h3 class="pcard__title">{p.name}</h3>
      <p class="pcard__desc">{p.desc}</p>

      <div class="pcard__specs">
        <span class="pcard__chip">{p.dimensions}</span>
        <span class="pcard__chip">{p.ageRange}</span>
        {p.height && <span class="pcard__chip">{p.height} altura</span>}
      </div>
    </div>

    <!-- Footer -->
    <div class="pcard__foot">
      <div class="pcard__price">
        <span class="pcard__price-from">Desde</span>
        <strong class="pcard__price-amount">${p.price.toLocaleString('es-MX')} MXN</strong>
        <span class="pcard__price-note">{p.priceNote}</span>
      </div>
      <span class="pcard__cta">
        Ver inflable
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </span>
    </div>

  </a>

  <!-- WA CTA fuera del link principal para no anidar interactivos -->
  <a
    href={waHref}
    class="pcard__wa-cta"
    target="_blank"
    rel="noopener"
    aria-label={`Cotizar ${p.name} por WhatsApp`}
    onclick="event.stopPropagation()"
  >
    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
    </svg>
    Cotizar por WhatsApp
  </a>
</article>

<style>
/* ── Tarjeta ── */
.pcard {
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 100%;
  box-shadow: var(--shadow-sm);
}
.pcard:hover {
  box-shadow: var(--shadow-lg);
}

.pcard__link {
  display: flex;
  flex-direction: column;
  height: 100%;
  color: inherit;
  text-decoration: none;
}

/* ── Imagen ── */
.pcard__media {
  position: relative;
  aspect-ratio: 4 / 3;
  overflow: hidden;
  background: var(--c-surface);
  flex-shrink: 0;
}
.pcard__img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.pcard__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,.25) 100%);
  pointer-events: none;
}

.pcard__badge {
  position: absolute;
  top: var(--sp-3);
  left: var(--sp-3);
  z-index: 2;
  padding: .2rem .65rem;
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .04em;
  color: #fff;
  background: rgba(255,255,255,.2);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,.3);
  border-radius: var(--radius-full);
}
.pcard__badge--hot {
  background: var(--c-primary);
  border-color: transparent;
  backdrop-filter: none;
}

/* ── Cuerpo ── */
.pcard__body {
  padding: var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  flex: 1;
}

.pcard__meta { display: flex; align-items: center; gap: var(--sp-2); }

.pcard__category {
  font-size: .7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--c-muted);
}

.pcard__title {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--c-ink);
  line-height: 1.25;
  margin: 0;
}

.pcard__desc {
  font-size: .85rem;
  color: var(--c-ink-2);
  line-height: 1.65;
  margin: 0;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.pcard__specs {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-2);
  margin-top: auto;
}

.pcard__chip {
  display: inline-flex;
  align-items: center;
  padding: .2rem .6rem;
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-full);
  font-size: .72rem;
  font-weight: 500;
  color: var(--c-muted);
}

/* ── Footer ── */
.pcard__foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-3);
  padding: var(--sp-4) var(--sp-5);
  border-top: 1px solid var(--c-border);
  background: var(--c-surface);
  flex-shrink: 0;
}

.pcard__price {
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.pcard__price-from {
  font-size: .68rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .05em;
  color: var(--c-muted);
}

.pcard__price-amount {
  font-family: var(--font-heading);
  font-size: 1.15rem;
  font-weight: 800;
  color: var(--c-primary);
  line-height: 1;
  letter-spacing: -0.01em;
}

.pcard__price-note {
  font-size: .68rem;
  color: var(--c-muted);
  line-height: 1.3;
}

.pcard__cta {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-1);
  padding: .55rem 1rem;
  background: var(--c-primary);
  color: #fff;
  font-family: var(--font-heading);
  font-size: .8rem;
  font-weight: 600;
  border-radius: var(--radius-md);
  white-space: nowrap;
  transition: background var(--transition), gap var(--transition);
  flex-shrink: 0;
}
.pcard:hover .pcard__cta {
  background: var(--c-primary-dark);
  gap: var(--sp-2);
}

/* WA CTA */
.pcard__wa-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--sp-2);
  width: 100%;
  padding: var(--sp-3) var(--sp-4);
  background: #25D366;
  color: #fff;
  font-family: var(--font-body);
  font-size: .82rem;
  font-weight: 600;
  text-decoration: none;
  border-top: 1px solid rgba(0,0,0,.06);
  transition: background var(--transition);
}
.pcard__wa-cta:hover { background: #1eb557; }
</style>
