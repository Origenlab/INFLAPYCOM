---
import { PROCESS } from '../config/site';

const icons: Record<string, string> = {
  message: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  calendar: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  truck: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  star: `<svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
};
---

<section class="process" id="proceso">
  <div class="process__container">
    <div class="process__header">
      <span class="process__eyebrow">¿Cómo funciona?</span>
      <h2 class="process__heading">De tu WhatsApp a la fiesta perfecta</h2>
    </div>

    <div class="process__grid">
      {PROCESS.map((step, i) => (
        <div class="process__step">
          <div class="process__step-top">
            <span class="process__badge">{step.step}</span>
            {i < PROCESS.length - 1 && (
              <span class="process__connector" aria-hidden="true"></span>
            )}
          </div>
          <div class="process__icon-wrap" set:html={icons[step.icon] ?? icons.message} />
          <h3 class="process__step-title">{step.title}</h3>
          <p class="process__step-desc">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process {
    background: #1a1a2e;
    padding-block: var(--section-py);
  }

  .process__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  .process__header {
    text-align: center;
    margin-bottom: var(--sp-12);
  }

  .process__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary);
    margin-bottom: var(--sp-3);
  }

  .process__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.2;
  }

  .process__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
  }

  @media (min-width: 768px) {
    .process__grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--sp-4);
    }
  }

  .process__step {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    position: relative;
  }

  .process__step-top {
    display: flex;
    align-items: center;
    gap: 0;
    position: relative;
  }

  .process__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: var(--radius-full);
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 800;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .process__connector {
    display: none;
  }

  @media (min-width: 768px) {
    .process__connector {
      display: block;
      flex: 1;
      height: 2px;
      background: rgba(255, 255, 255, 0.12);
      margin-left: var(--sp-2);
    }
  }

  .process__icon-wrap {
    color: var(--c-primary-light);
    margin-top: var(--sp-2);
  }

  .process__step-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }

  .process__step-desc {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.55);
  }
</style>
