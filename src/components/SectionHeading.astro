---
// SectionHeading.astro — Encabezado de sección reutilizable.
// Eyebrow: barra horizontal + texto (estándar OrigenLab, igual que EJEMPLOS).
// Layouts: 'simple' centrado/izquierda | 'duo' título izq + body/desc der.
// Props legacy: center={true} → layout='simple' align='center'.
interface Props {
  eyebrow?: string;
  title: string;
  /** Segunda línea del título resaltada con color de acento. */
  titleAccent?: string;
  desc?: string;
  /** 'simple' (1 col) | 'duo' (título izq, body der). Default auto. */
  layout?: 'simple' | 'duo';
  /** Solo en 'simple': alineación del bloque. */
  align?: 'center' | 'left';
  /** Solo en 'duo': párrafos de la columna derecha. */
  body?: string[];
  /** true → textos en blanco (fondo oscuro). */
  dark?: boolean;
  /** Legado: center={true} equivale a layout='simple' align='center'. */
  center?: boolean;
}
const {
  eyebrow,
  title,
  titleAccent,
  desc,
  layout: layoutProp,
  align: alignProp,
  body = [],
  dark = false,
  center,
} = Astro.props;

// Resolver layout y align respetando legacy `center`
const layout = layoutProp ?? (!center && desc && body.length === 0 ? 'duo' : 'simple');
const align  = alignProp ?? (center ? 'center' : layout === 'simple' ? 'center' : 'left');
---

<header class:list={[
  'sech',
  `sech--${layout}`,
  layout === 'simple' && `sech--${align}`,
  { 'sech--dark': dark },
]}>
  <div class="sech__head">
    {eyebrow && (
      <p class="sech__eyebrow">
        <span class="sech__eyebrow-bar" aria-hidden="true"></span>
        {eyebrow}
      </p>
    )}
    <h2 class="sech__title">
      {title}
      {titleAccent && <><br /><span class="sech__accent">{titleAccent}</span></>}
    </h2>
    {desc && layout === 'simple' && <p class="sech__desc">{desc}</p>}
  </div>

  {layout === 'duo' && (
    <div class="sech__body">
      {body.length > 0
        ? body.map((p: string) => <p class="sech__body-p">{p}</p>)
        : desc && <p class="sech__body-p">{desc}</p>
      }
    </div>
  )}
</header>

<style>
  .sech { margin-bottom: var(--sp-10); }

  /* Eyebrow: barra + texto */
  .sech__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--text-xs, .75rem);
    font-weight: var(--weight-bold, 700);
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--c-primary);
    margin: 0 0 var(--sp-3);
  }
  .sech__eyebrow-bar {
    width: 20px;
    height: 2px;
    background: currentColor;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* Título */
  .sech__title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--c-ink);
    letter-spacing: -0.02em;
    margin: 0;
  }
  .sech__accent { color: var(--c-primary); }

  /* Desc (solo en simple) */
  .sech__desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    margin: var(--sp-3) 0 0;
    max-width: 60ch;
  }

  /* Layout: simple */
  .sech--simple { text-align: left; }
  .sech--center { text-align: center; }
  .sech--center .sech__eyebrow { justify-content: center; }
  .sech--center .sech__desc { margin-inline: auto; }

  /* Layout: duo — 2 columnas */
  .sech--duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }
  .sech--duo .sech__head {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .sech--duo .sech__head .sech__eyebrow { margin-bottom: 0; }

  .sech__body { display: flex; flex-direction: column; gap: var(--sp-4); }
  .sech__body-p {
    font-size: 1rem;
    color: var(--c-ink-2);
    line-height: 1.7;
    margin: 0;
  }

  /* Dark mode */
  .sech--dark .sech__title { color: #fff; }
  .sech--dark .sech__desc,
  .sech--dark .sech__body-p { color: rgba(255,255,255,.75); }
  .sech--dark .sech__eyebrow { color: var(--c-primary); }

  @media (max-width: 768px) {
    .sech--duo { grid-template-columns: 1fr; gap: var(--sp-5); }
  }
</style>
