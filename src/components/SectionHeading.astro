---
interface Props {
  eyebrow: string;
  title: string;
  desc?: string;
  center?: boolean;
}
const { eyebrow, title, desc, center = false } = Astro.props;
---

<div class:list={['section-heading', { 'section-heading--center': center, 'section-heading--duo': !center && desc }]}>
  <div class="section-heading__main">
    <span class="sh-eyebrow">{eyebrow}</span>
    <h2 class="sh-title">{title}</h2>
  </div>
  {desc && <p class="sh-desc">{desc}</p>}
</div>

<style>
  .section-heading {
    margin-bottom: var(--sp-10);
  }

  .section-heading--duo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-8);
    align-items: end;
    text-align: left;
  }

  @media (max-width: 768px) {
    .section-heading--duo {
      grid-template-columns: 1fr;
    }
  }

  .section-heading--center {
    text-align: center;
  }

  .sh-eyebrow {
    display: inline-flex;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: rgba(var(--c-primary-rgb), 0.08);
    border: 1px solid rgba(var(--c-primary-rgb), 0.2);
    border-radius: var(--radius-full);
    padding: var(--sp-1) var(--sp-3);
    margin-bottom: var(--sp-3);
  }

  .sh-title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }

  .sh-desc {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    padding-top: var(--sp-2);
  }
</style>
