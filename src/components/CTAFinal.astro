---
import { WA_MESSAGES, CONTACT } from '../config/site';
import { waUrl } from '../lib/utils';

interface Props {
  variant?: 'red' | 'dark' | 'light';
}
const { variant = 'red' } = Astro.props;
---

<section class:list={['cta-final', `cta-final--${variant}`]}>
  <div class="cta-final__container">
    <p class="cta-final__eyebrow">¿Lista tu fecha? Reserva hoy</p>
    <h2 class="cta-final__heading">Tu fiesta perfecta<br />empieza aquí</h2>
    <p class="cta-final__sub">
      Respuesta inmediata por WhatsApp. Instalación y retiro incluidos, precios sin sorpresas desde $800 MXN.
    </p>
    <div class="cta-final__actions">
      <a
        href={waUrl(WA_MESSAGES.cotizar)}
        target="_blank"
        rel="noopener"
        class="btn-wa"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Escribir por WhatsApp
      </a>
      <a href="/catalogo" class="btn-ghost">
        Ver catálogo
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    padding-block: var(--section-py);
    text-align: center;
  }

  /* ── Variante red (default) ── */
  .cta-final--red {
    background: var(--c-primary);
  }
  .cta-final--red .cta-final__heading { color: #fff; }
  .cta-final--red .cta-final__sub { color: rgba(255, 255, 255, 0.85); }
  .cta-final--red .btn-ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.5);
  }
  .cta-final--red .btn-ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* ── Variante dark ── */
  .cta-final--dark {
    background: var(--c-ink);
  }
  .cta-final--dark .cta-final__heading { color: #fff; }
  .cta-final--dark .cta-final__sub { color: rgba(255, 255, 255, 0.75); }
  .cta-final--dark .btn-ghost {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.4);
  }
  .cta-final--dark .btn-ghost:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.08);
  }

  /* ── Variante light ── */
  .cta-final--light {
    background: var(--c-surface);
  }
  .cta-final--light .cta-final__heading { color: var(--c-ink); }
  .cta-final--light .cta-final__sub { color: var(--c-ink-2); }
  .cta-final--light .btn-ghost {
    color: var(--c-ink-2);
    border-color: var(--c-border);
  }
  .cta-final--light .btn-ghost:hover {
    border-color: var(--c-ink-2);
    background: rgba(0, 0, 0, 0.04);
  }

  .cta-final__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  .cta-final__eyebrow {
    font-family: var(--font-body);
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(255,255,255,.6);
    margin: 0 0 var(--sp-3);
  }
  .cta-final--light .cta-final__eyebrow { color: var(--c-muted); }

  .cta-final__heading {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    margin-bottom: var(--sp-4);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .cta-final__sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    margin-bottom: var(--sp-8);
    line-height: 1.65;
    max-width: 48ch;
    margin-inline: auto;
    opacity: .9;
  }

  .cta-final__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
    align-items: center;
  }

  /* ── WhatsApp button ── */
  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--c-wa);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-wa:hover {
    background: #20ba58;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Ghost button (CTA secundario) ── */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: transparent;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    border: 2px solid;
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-ghost:hover {
    transform: translateY(-1px);
  }
</style>
