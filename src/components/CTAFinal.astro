---
import { WA_MESSAGES } from '../config/site';
import { waUrl, telUrl } from '../lib/utils';
---

<section class="cta-final">
  <div class="cta-final__container">
    <h2 class="cta-final__heading">¿Listo para la fiesta?</h2>
    <p class="cta-final__sub">
      Cotiza en WhatsApp en menos de 5 minutos. Instalación incluida, precios sin sorpresas.
    </p>
    <div class="cta-final__actions">
      <a
        href={waUrl(WA_MESSAGES.cotizar)}
        target="_blank"
        rel="noopener"
        class="btn-wa"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Escribir por WhatsApp
      </a>
      <a href={telUrl()} class="btn-outline">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.12 6.12l.96-.96a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
        Llamar ahora
      </a>
    </div>
  </div>
</section>

<style>
  .cta-final {
    background: var(--c-primary);
    padding-block: var(--section-py);
    text-align: center;
  }

  .cta-final__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  .cta-final__heading {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 5vw, 3rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: var(--sp-4);
    line-height: 1.1;
  }

  .cta-final__sub {
    font-family: var(--font-body);
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--sp-8);
    line-height: 1.6;
    max-width: 50ch;
    margin-inline: auto;
  }

  .cta-final__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: center;
    align-items: center;
  }

  /* ── WhatsApp button ── */
  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--c-wa);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-wa:hover {
    background: #20ba58;
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Outline button ── */
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: transparent;
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    border: 2px solid rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-outline:hover {
    border-color: #fff;
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-1px);
  }
</style>
