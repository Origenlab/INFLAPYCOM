---
import { SITE, STATS, WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';
---

<section class="hero">
  <div class="hero__container">
    <!-- Left column -->
    <div class="hero__left">
      <span class="hero__eyebrow">30 años de experiencia</span>
      <h1 class="hero__title">Renta de Inflables para Fiestas Increíbles en CDMX</h1>
      <p class="hero__desc">
        Castillos, toboganes y brincolines desde $800 MXN. Instalación incluida. Cubrimos toda la CDMX y Estado de México.
      </p>
      <div class="hero__ctas">
        <a
          href={waUrl(WA_MESSAGES.cotizar)}
          target="_blank"
          rel="noopener"
          class="btn-primary"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Cotizar por WhatsApp
        </a>
        <a href="/catalogo" class="btn-ghost">Ver catálogo</a>
      </div>
    </div>

    <!-- Right column (hidden on mobile) -->
    <div class="hero__right" aria-hidden="true">
      <div class="hero__card">
        <div class="hero__card-img" style={`background-image: url('${SITE.ogImage}')`}></div>
        <div class="hero__card-overlay">
          <div class="hero__stats-overlay">
            {STATS.slice(0, 2).map((s) => (
              <div class="hero__stat-pill">
                <span class="hero__stat-val">{s.value}</span>
                <span class="hero__stat-lbl">{s.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #fff 0%, #fff5f0 55%, #ffe8da 100%);
    padding-block: var(--section-py);
    overflow: hidden;
  }

  .hero__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-10);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero__container {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: rgba(var(--c-primary-rgb), 0.08);
    border: 1px solid rgba(var(--c-primary-rgb), 0.2);
    border-radius: var(--radius-full);
    padding: var(--sp-1) var(--sp-3);
    margin-bottom: var(--sp-4);
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--c-ink);
    margin-bottom: var(--sp-5);
    letter-spacing: -0.02em;
  }

  .hero__desc {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--c-ink-2);
    margin-bottom: var(--sp-8);
    max-width: 52ch;
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
  }

  /* ── Primary button ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--c-primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  /* ── Ghost button ── */
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: transparent;
    color: var(--c-ink);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    border: 2px solid var(--c-border);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-ghost:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    transform: translateY(-1px);
  }

  /* ── Right side card ── */
  .hero__right {
    display: none;
  }

  @media (min-width: 1024px) {
    .hero__right {
      display: block;
    }
  }

  .hero__card {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    box-shadow: var(--shadow-lg);
  }

  .hero__card-img {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-color: #ffe8da;
  }

  .hero__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(20,24,31,0.65) 0%, transparent 55%);
    display: flex;
    align-items: flex-end;
    padding: var(--sp-6);
  }

  .hero__stats-overlay {
    display: flex;
    gap: var(--sp-3);
    width: 100%;
  }

  .hero__stat-pill {
    flex: 1;
    background: rgba(255,255,255,0.12);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: var(--radius-lg);
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero__stat-val {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 800;
    color: #fff;
    line-height: 1;
  }

  .hero__stat-lbl {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: rgba(255,255,255,0.8);
  }
</style>
