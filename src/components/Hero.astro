---
import { WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';
---

<section class="hero">
  <div class="hero__container">

    <!-- Columna izquierda: eyebrow + H1 -->
    <div class="hero__left">
      <span class="hero__eyebrow">30 años de experiencia · CDMX y EdoMex</span>
      <h1 class="hero__title">
        Renta de Inflables para
        <mark class="hero__accent">Fiestas Increíbles</mark>
        en Ciudad de México
      </h1>
    </div>

    <!-- Columna derecha: dos párrafos + CTAs -->
    <div class="hero__right">
      <p class="hero__p">
        Castillos, toboganes y brincolines para niños de todas las edades. Instalación y retiro incluidos — tú solo enfócate en disfrutar la fiesta.
      </p>
      <p class="hero__p">
        Más de 10,000 eventos en CDMX y Estado de México. Precios desde $800 MXN con seguro de responsabilidad civil y equipo sanitizado antes de cada renta.
      </p>
      <div class="hero__ctas">
        <a
          href={waUrl(WA_MESSAGES.cotizar)}
          target="_blank"
          rel="noopener"
          class="btn-primary"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
          </svg>
          Cotizar por WhatsApp
        </a>
        <a href="/catalogo" class="btn-ghost">Ver catálogo</a>
      </div>
    </div>

  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #fff 0%, #fff5f0 55%, #ffe8da 100%);
    padding-block: var(--section-py);
  }

  .hero__container {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-8);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero__container {
      grid-template-columns: 1fr 1fr;
      gap: clamp(2.5rem, 5vw, 4rem);
    }
  }

  /* ── Izquierda ── */
  .hero__left {
    display: flex;
    flex-direction: column;
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--c-primary);
    background: rgba(var(--c-primary-rgb), 0.08);
    border: 1px solid rgba(var(--c-primary-rgb), 0.2);
    border-radius: var(--radius-full);
    padding: var(--sp-1) var(--sp-3);
    margin-bottom: var(--sp-4);
    width: fit-content;
  }

  .hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.1;
    color: var(--c-ink);
    letter-spacing: -0.02em;
  }

  .hero__accent {
    color: var(--c-primary);
    background: none;
    font-style: normal;
  }

  /* ── Derecha ── */
  .hero__right {
    display: flex;
    flex-direction: column;
    gap: var(--sp-5);
  }

  .hero__p {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--c-ink-2);
  }

  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    align-items: center;
    padding-top: var(--sp-2);
  }

  /* ── Botones ── */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-primary:hover {
    background: var(--c-primary-dark);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: var(--c-ink);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-full);
    border: 2px solid var(--c-border);
    text-decoration: none;
    transition: var(--transition);
    white-space: nowrap;
  }

  .btn-ghost:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    transform: translateY(-1px);
  }
</style>
