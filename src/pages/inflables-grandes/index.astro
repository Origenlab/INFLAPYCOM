---
import PageLayout from '../../layouts/PageLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SITE, CONTACT, WA_MESSAGES, getProductsByCategory } from '../../config/site';
import { waUrl, telUrl } from '../../lib/utils';
import { getCollection } from 'astro:content';

const products = getProductsByCategory('grandes');
const waHref = waUrl(WA_MESSAGES.cotizar);
const telHref = telUrl();

// Blog articles for grandes category
const grandesProducts = ['barco-pirata', 'extremo', 'castillo-blanco'];
const blogArticles = (await getCollection('blog'))
  .filter(p => p.data.product && grandesProducts.includes(p.data.product))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

function readTime(body: string | undefined) {
  if (!body) return 4;
  return Math.max(1, Math.round(body.split(/\s+/).filter(Boolean).length / 200));
}

const GRANDES_LABELS: Record<string, string> = {
  'barco-pirata': 'Barco Pirata',
  'extremo': 'Circuito Extremo',
  'castillo-blanco': 'Castillo Blanco',
};

const title = 'Inflables grandes | Toboganes y circuitos 5 a 15 años | Renta CDMX';
const description =
  'Inflables grandes con toboganes y circuitos para 5 a 15 años en renta CDMX. Barco Pirata, Circuito Extremo y Castillo Blanco desde $1,800 MXN. Instalación incluida.';
---

<PageLayout
  title={title}
  description={description}
  canonical={`${SITE.url}/inflables-grandes`}
>
  <!-- 1. Category hero -->
  <section class="cat-hero">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Inicio', href: '/' },
        { label: 'Catálogo', href: '/catalogo' },
        { label: 'Inflables Grandes' },
      ]} />
      <span class="eyebrow">Categoría</span>
      <h1 class="cat-heading">Inflables Grandes (5–15 años)</h1>
      <p class="cat-sub">
        Los inflables más espectaculares de nuestra flota. Para jardines amplios, eventos
        escolares y fiestas donde se busca el máximo impacto y diversión.
      </p>
      <div class="cat-meta">
        <span class="count-badge">{products.length} modelos disponibles</span>
        <span class="cat-price-hint">Desde <strong>$1,800 MXN</strong> / evento</span>
      </div>
    </div>
  </section>

  <!-- 2. Products grid -->
  <section class="cat-grid">
    <div class="container">
      <div class="products-grid">
        {products.map((p, i) => (
          <ProductCard product={p} eager={i === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- 3. Guide: cómo elegir -->
  <section class="guide-section">
    <div class="container">
      <div class="guide-inner">
        <div class="guide-text">
          <span class="eyebrow">Guía de elección</span>
          <h2 class="guide-heading">¿Cuál inflable grande necesita tu evento?</h2>
          <p>
            Los inflables grandes requieren más espacio — mínimo 4×5 m con techos de 3 m o
            exterior — pero generan el mayor impacto visual y la mayor diversión sostenida.
            Elige según el tipo de evento y el espacio disponible.
          </p>
          <ul class="guide-list">
            <li>
              <strong><a href="/inflables-grandes/barco-pirata">Barco Pirata:</a></strong>
              temática náutica icónica con tobogán integrado. Ideal para fiestas de 6–12 años
              y eventos al aire libre con espacio moderado.
            </li>
            <li>
              <strong><a href="/inflables-grandes/extremo">Circuito Extremo:</a></strong>
              el inflable más completo — túneles, escalada, tobogán y obstáculos. Perfecto para
              kermeses, olimpiadas infantiles y eventos escolares de 7–15 años.
            </li>
            <li>
              <strong><a href="/inflables-grandes/castillo-blanco">Castillo Blanco:</a></strong>
              elegancia y versatilidad para bodas, XV años, comuniones y eventos formales.
              Diseño neutro que combina con cualquier decoración.
            </li>
          </ul>
          <a href="/articulos" class="guide-cta">
            Leer guías completas en el blog
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>

        <aside class="guide-table-wrap">
          <h3 class="guide-table-title">Comparativa rápida</h3>
          <table class="guide-table">
            <thead>
              <tr>
                <th>Inflable</th>
                <th>Mejor para</th>
                <th>Desde</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><a href="/inflables-grandes/barco-pirata">Barco Pirata</a></td>
                <td>Fiestas infantiles</td>
                <td>$1,800</td>
              </tr>
              <tr>
                <td><a href="/inflables-grandes/extremo">Circuito Extremo</a></td>
                <td>Kermeses y eventos</td>
                <td>$2,200</td>
              </tr>
              <tr>
                <td><a href="/inflables-grandes/castillo-blanco">Castillo Blanco</a></td>
                <td>Bodas y XV años</td>
                <td>$2,000</td>
              </tr>
            </tbody>
          </table>
          <p class="guide-table-note">* Precios aproximados. Confirma disponibilidad por WhatsApp.</p>
        </aside>
      </div>
    </div>
  </section>

  <!-- 4. Blog articles -->
  {blogArticles.length > 0 && (
    <section class="cat-articles">
      <div class="container">
        <div class="cat-articles-header">
          <div>
            <span class="eyebrow">Desde el blog</span>
            <h2 class="cat-articles-title">Guías para eventos con inflables grandes</h2>
          </div>
          <a href="/articulos" class="cat-articles-all">
            Ver todos los artículos
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
        <div class="cat-articles-grid">
          {blogArticles.map(post => {
            const rt = readTime(post.body);
            const dateStr = post.data.date.toLocaleDateString('es-MX', { month: 'short', day: 'numeric', year: 'numeric' });
            const productLabel = post.data.product ? GRANDES_LABELS[post.data.product] : null;
            return (
              <article class="cat-article-card">
                {post.data.image && (
                  <a href={`/articulos/${post.id}`} class="cat-article-img" tabindex="-1" aria-hidden="true">
                    <img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="480" height="270" loading="lazy" decoding="async" onerror="this.src='/img/placeholder.svg'" />
                  </a>
                )}
                <div class="cat-article-body">
                  <div class="cat-article-meta">
                    {productLabel && <span class="cat-product-chip">{productLabel}</span>}
                    <time>{dateStr}</time>
                    <span aria-hidden="true">·</span>
                    <span>{rt} min</span>
                  </div>
                  <h3 class="cat-article-title">
                    <a href={`/articulos/${post.id}`}>{post.data.title}</a>
                  </h3>
                  <p class="cat-article-excerpt">{post.data.excerpt}</p>
                  <a href={`/articulos/${post.id}`} class="cat-article-read">
                    Leer guía
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>
  )}

  <!-- 5. CTA strip -->
  <section class="cta-strip">
    <div class="container cta-inner">
      <div class="cta-text">
        <p class="cta-label">¿Tienes espacio para uno de estos?</p>
        <p class="cta-sub">Mándanos las medidas y buscamos el modelo perfecto para tu evento.</p>
      </div>
      <div class="cta-actions">
        <a href={waHref} class="btn btn-wa" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.955 7.955 0 01-4.078-1.118l-.29-.173-3.008.853.854-2.938-.19-.302A7.955 7.955 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
          Cotizar por WhatsApp
        </a>
        <a href={telHref} class="btn btn-ghost">
          Llamar: {CONTACT.phoneDisplay}
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
.container {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
}

.cat-hero {
  background: var(--c-white);
  padding-block: var(--sp-12) var(--sp-8);
  border-bottom: 1px solid var(--c-border);
}
.eyebrow {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-primary);
  margin-bottom: var(--sp-2);
}
.cat-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800;
  color: var(--c-ink);
  line-height: 1.15;
  margin-bottom: var(--sp-3);
}
.cat-sub {
  font-size: 1rem;
  color: var(--c-muted);
  line-height: 1.6;
  max-width: 600px;
  margin-bottom: var(--sp-5);
}
.cat-meta { display: flex; align-items: center; gap: var(--sp-4); flex-wrap: wrap; }
.count-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.75rem;
  background: color-mix(in srgb, var(--c-primary) 10%, transparent);
  color: var(--c-primary);
  font-size: 0.8rem;
  font-weight: 700;
  border-radius: var(--radius-full);
}
.cat-price-hint { font-size: 0.9rem; color: var(--c-muted); }
.cat-price-hint strong { color: var(--c-ink); font-weight: 700; }

.cat-grid { padding-block: var(--section-py); background: var(--c-surface); }
.products-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-6); }
@media (max-width: 900px) { .products-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) { .products-grid { grid-template-columns: 1fr; } }

/* ── Guide ── */
.guide-section {
  padding-block: var(--section-py);
  background: var(--c-white);
  border-top: 1px solid var(--c-border);
}
.guide-inner {
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: var(--sp-12);
  align-items: start;
}
@media (max-width: 900px) { .guide-inner { grid-template-columns: 1fr; } }

.guide-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.3rem, 2.5vw, 1.8rem);
  font-weight: 800;
  color: var(--c-ink);
  margin-bottom: var(--sp-4);
  letter-spacing: -0.02em;
}
.guide-text p {
  font-size: 0.95rem;
  color: var(--c-ink-2);
  line-height: 1.7;
  margin-bottom: var(--sp-5);
}
.guide-list {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}
.guide-list li {
  font-size: 0.92rem;
  color: var(--c-ink-2);
  line-height: 1.55;
  padding-left: 1.4rem;
  position: relative;
}
.guide-list li::before { content: '→'; position: absolute; left: 0; color: var(--c-primary); font-weight: 700; }
.guide-list a { color: var(--c-primary); text-decoration: underline; }
.guide-list a:hover { text-decoration: none; }

.guide-cta {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-heading);
  font-size: 0.88rem;
  font-weight: 700;
  color: var(--c-primary);
  text-decoration: none;
  transition: gap 0.15s ease;
}
.guide-cta:hover { gap: var(--sp-3); text-decoration: underline; }

.guide-table-wrap {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  padding: var(--sp-6);
}
.guide-table-title {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--c-ink);
  margin-bottom: var(--sp-4);
}
.guide-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.875rem;
}
.guide-table th {
  text-align: left;
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--c-muted);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--c-border);
}
.guide-table td {
  padding: var(--sp-2-5) 0;
  color: var(--c-ink-2);
  border-bottom: 1px solid var(--c-border);
  line-height: 1.4;
}
.guide-table td a { color: var(--c-primary); text-decoration: none; }
.guide-table td a:hover { text-decoration: underline; }
.guide-table td:last-child { font-weight: 700; color: var(--c-ink); text-align: right; }
.guide-table tr:last-child td { border-bottom: none; }
.guide-table-note { font-size: 0.75rem; color: var(--c-muted); margin-top: var(--sp-3); margin-bottom: 0; }

/* ── Blog articles ── */
.cat-articles {
  padding-block: var(--section-py);
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
}
.cat-articles-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--sp-4);
  margin-bottom: var(--sp-8);
  flex-wrap: wrap;
}
.cat-articles-title {
  font-family: var(--font-heading);
  font-size: clamp(1.2rem, 2.5vw, 1.6rem);
  font-weight: 800;
  color: var(--c-ink);
  margin: 0;
  letter-spacing: -0.02em;
}
.cat-articles-all {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  padding: 0.55rem 1.1rem;
  border: 1.5px solid var(--c-border);
  border-radius: var(--radius-md);
  font-family: var(--font-heading);
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--c-ink-2);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.15s ease;
}
.cat-articles-all:hover { border-color: var(--c-primary); color: var(--c-primary); }

.cat-articles-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--sp-6);
}
@media (max-width: 700px) { .cat-articles-grid { grid-template-columns: 1fr; } }

.cat-article-card {
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}
.cat-article-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-3px); }

.cat-article-img {
  display: block;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  background: var(--c-surface);
}
.cat-article-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
.cat-article-card:hover .cat-article-img img { transform: scale(1.04); }

.cat-article-body {
  padding: var(--sp-5);
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  flex: 1;
}
.cat-article-meta {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-2);
  font-size: 0.75rem;
  color: var(--c-muted);
  font-weight: 500;
}
.cat-product-chip {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--c-primary);
  background: rgba(var(--c-primary-rgb), 0.1);
  padding: 0.18rem 0.55rem;
  border-radius: var(--radius-full);
}
.cat-article-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--c-ink);
  margin: 0;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cat-article-title a { text-decoration: none; color: inherit; }
.cat-article-title a:hover { color: var(--c-primary); }
.cat-article-excerpt {
  font-size: 0.84rem;
  color: var(--c-ink-2);
  line-height: 1.6;
  margin: 0;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.cat-article-read {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--c-primary);
  text-decoration: none;
  margin-top: auto;
  transition: gap 0.15s ease;
}
.cat-article-read:hover { gap: var(--sp-2); text-decoration: underline; }

/* ── CTA strip ── */
.cta-strip { background: var(--c-ink); padding-block: var(--sp-8); }
.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-6);
  flex-wrap: wrap;
}
.cta-label { font-family: var(--font-heading); font-size: 1.1rem; font-weight: 700; color: var(--c-white); margin: 0 0 var(--sp-1); }
.cta-sub { font-size: 0.9rem; color: rgba(255,255,255,0.65); margin: 0; }
.cta-actions { display: flex; align-items: center; gap: var(--sp-3); flex-wrap: wrap; flex-shrink: 0; }
.btn {
  display: inline-flex; align-items: center; gap: var(--sp-2);
  padding: .75rem 1.5rem; font-family: var(--font-heading); font-size: 0.875rem; font-weight: 600;
  border-radius: var(--radius-md); border: 2px solid transparent; cursor: pointer;
  transition: background var(--transition), transform var(--transition), box-shadow var(--transition);
  white-space: nowrap; line-height: 1; text-decoration: none;
}
.btn svg { flex-shrink: 0; width: 18px; height: 18px; }
.btn-wa { background: var(--c-wa); color: #04210f; box-shadow: 0 4px 16px rgba(37,211,102,.3); }
.btn-wa:hover { background: #1ebe5a; transform: translateY(-1px); }
.btn-ghost { background: transparent; color: var(--c-white); border-color: rgba(255,255,255,.4); }
.btn-ghost:hover { border-color: var(--c-white); background: rgba(255,255,255,.08); }
@media (max-width: 640px) {
  .cta-inner { flex-direction: column; align-items: flex-start; }
  .cta-actions { width: 100%; }
  .btn { flex: 1; justify-content: center; }
}
</style>
