---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await render(post);

// Tiempo de lectura estimado (~200 palabras/min)
const wordCount = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(wordCount / 200));

// Artículos relacionados: mismo producto primero, luego recientes
const sameProduct = allPosts
  .filter(p => p.id !== post.id && p.data.product === post.data.product)
  .slice(0, 2);

const filler = sameProduct.length < 2
  ? allPosts
      .filter(p => p.id !== post.id && !sameProduct.find(r => r.id === p.id))
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
      .slice(0, 2 - sameProduct.length)
  : [];

const relatedPosts = [...sameProduct, ...filler].map(p => ({
  id: p.id,
  title: p.data.title,
  excerpt: p.data.excerpt,
  image: p.data.image,
  imageAlt: p.data.imageAlt,
  date: p.data.date,
  tags: p.data.tags,
  product: p.data.product,
}));
---

<ArticleLayout
  title={post.data.title}
  excerpt={post.data.excerpt}
  date={post.data.date}
  product={post.data.product}
  productSlug={post.data.productSlug}
  image={post.data.image}
  imageAlt={post.data.imageAlt}
  author={post.data.author}
  slug={post.id}
  tags={post.data.tags}
  readingTime={readingTime}
  relatedPosts={relatedPosts}
>
  <Content />
</ArticleLayout>
