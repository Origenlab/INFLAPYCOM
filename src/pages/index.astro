---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionMenu from '../components/SectionMenu.astro';
import SectionHeading from '../components/SectionHeading.astro';
import StatsStrip from '../components/StatsStrip.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Reviews from '../components/Reviews.astro';
import Coverage from '../components/Coverage.astro';
import FAQ from '../components/FAQ.astro';
import CTAFinal from '../components/CTAFinal.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import CompanyAbout from '../components/CompanyAbout.astro';
import { SITE, PRODUCTS, SERVICES, CONTACT, KEYWORDS } from '../config/site';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.brand,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": "+52" + CONTACT.phone,
  "image": SITE.url + SITE.ogImage,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ciudad de México",
    "addressRegion": "CMX",
    "addressCountry": "MX"
  },
  "areaServed": "Ciudad de México y Estado de México",
  "openingHours": "Mo-Su 08:00-20:00",
  "priceRange": "$800-$2500 MXN",
  "currenciesAccepted": "MXN",
  "paymentAccepted": "Efectivo, Transferencia bancaria",
  "hasMap": "https://maps.google.com/?q=Ciudad+de+Mexico"
});

const iconSvgs: Record<string, string> = {
  truck: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  shield: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  eye: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  'map-pin': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  heart: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
};
---

<PageLayout
  keywords={KEYWORDS}
  description="Renta de inflables en CDMX: castillos, toboganes y brincolines desde $800 MXN. Instalación incluida. 30 años de experiencia en Ciudad de México y Estado de México."
  schema={schema}
>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. TrustBar -->
  <TrustBar />

  <!-- 3. SectionMenu -->
  <SectionMenu />

  <!-- 4. Catálogo — grid rápido -->
  <section id="catalogo" class="section-catalog">
    <div class="container">
      <SectionHeading
        eyebrow="Catálogo completo"
        title="Inflables para renta"
        titleAccent="en CDMX y EdoMex"
        layout="duo"
        body={[
          'Todos nuestros inflables están desinfectados, certificados y listos para entrega en CDMX y zona metropolitana. Elige el modelo que se adapte a tu espacio y a la edad de los niños.',
          '¿No encuentras el indicado? Escríbenos por WhatsApp — te ayudamos a elegir el modelo perfecto para tu evento, espacio y presupuesto en minutos.',
        ]}
      />
      <div class="catalog-grid">
        {PRODUCTS.map((p, i) => (
          <ProductCard product={p} eager={i === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- 4b. ProductShowcase — detalle alternado por modelo -->
  <ProductShowcase />

  <!-- 5. CompanyAbout -->
  <CompanyAbout />

  <!-- 6. Servicios -->
  <section id="servicios" class="section-services">
    <div class="container">
      <SectionHeading
        eyebrow="¿Por qué elegirnos?"
        title="Servicio profesional"
        titleAccent="en cada renta"
        layout="duo"
        body={[
          'Más de 10,000 eventos atendidos. Instalación incluida, equipos sanitizados y atención personalizada de inicio a fin. Tu fiesta, sin preocupaciones.',
          'Cubrimos toda la CDMX y zona metropolitana sin costo de traslado adicional. Llegamos puntual, montamos y recogemos todo al terminar.',
        ]}
      />
      <div class="services-grid">
        {SERVICES.map((s) => (
          <article class="svc-card">
            <div
              class="svc-card__icon"
              aria-hidden="true"
              set:html={iconSvgs[s.icon] ?? `<span>${s.icon[0].toUpperCase()}</span>`}
            />
            <div class="svc-card__content">
              <h3 class="svc-card__title">{s.title}</h3>
              <p class="svc-card__desc">{s.desc}</p>
            </div>
            <span class="svc-card__tag">{s.tag}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. ProcessSteps -->
  <ProcessSteps />

  <!-- 7. Reviews -->
  <Reviews />

  <!-- 8. StatsStrip -->
  <StatsStrip />

  <!-- 9. Coverage -->
  <Coverage />

  <!-- 10. FAQ -->
  <FAQ />

  <!-- 11. CTAFinal -->
  <CTAFinal variant="red" />
</PageLayout>

<style>
/* ── Container ── */
.container {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
}

/* ── Catalog section ── */
.section-catalog {
  padding-block: var(--section-py);
}

.catalog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-6);
}

@media (max-width: 900px) {
  .catalog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .catalog-grid {
    grid-template-columns: 1fr;
  }
}

/* ── Services section ── */
.section-services {
  padding-block: var(--section-py);
  background: var(--c-surface);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-5);
}

@media (max-width: 900px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 560px) {
  .services-grid { grid-template-columns: 1fr; }
}

/* Service card — versión limpia */
.svc-card {
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  padding: var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  box-shadow: var(--shadow-sm);
  transition: box-shadow .2s ease, transform .2s ease;
}
.svc-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.svc-card__icon {
  width: 52px;
  height: 52px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--c-primary-rgb), .1);
  color: var(--c-primary);
  border-radius: var(--radius-lg);
  flex-shrink: 0;
}

.svc-card__content {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
  flex: 1;
}

.svc-card__title {
  font-family: var(--font-heading);
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--c-ink);
  line-height: 1.25;
  margin: 0;
}

.svc-card__desc {
  font-size: .875rem;
  color: var(--c-ink-2);
  line-height: 1.65;
  margin: 0;
}

.svc-card__tag {
  align-self: flex-start;
  display: inline-flex;
  padding: .22rem .7rem;
  background: rgba(var(--c-primary-rgb), .08);
  color: var(--c-primary);
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .05em;
  text-transform: uppercase;
  border-radius: var(--radius-full);
  margin-top: auto;
}
</style>
