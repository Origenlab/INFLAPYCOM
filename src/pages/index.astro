---
// ============================================================================
// index.astro — HOME de INFLAPY (L1). Orquestador limpio, módulo por módulo,
// homologado al estándar canónico EJEMPLOS.mx. Cero datos hardcodeados: todo
// sale de src/config/site.ts (SSoT). Schema vía lib/seo (sin reseñas fabricadas).
// Orden: Hero → Franja (convierte) → Confianza → Catálogo → Spotlights (sin
// zig-zag, mismo acomodo) → Guía de selección → Empresa → Beneficios → Proceso
// → Reseñas → Cobertura → FAQ+Contacto → Cierre.
// ============================================================================
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionMenu from '../components/SectionMenu.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProductCard from '../components/ProductCard.astro';
import CategoryFeature from '../components/CategoryFeature.astro';
import RiskGuide from '../components/RiskGuide.astro';
import CompanyAbout from '../components/CompanyAbout.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Reviews from '../components/Reviews.astro';
import Coverage from '../components/Coverage.astro';
import FAQWithContact from '../components/FAQWithContact.astro';
import CTAFinal from '../components/CTAFinal.astro';
import BlogPreview from '../components/BlogPreview.astro';
import { PRODUCTS, SERVICES, KEYWORDS, WA_MESSAGES } from '../config/site';
import { buildSchema } from '../lib/seo';
import { waUrl } from '../lib/utils';

const schema = buildSchema({ pageType: 'home' });

// ── Inflables estrella para los spotlights (datos reales del catálogo) ──
const mini      = PRODUCTS.find((p) => p.id === 'mini-castillo')!;
const jungla    = PRODUCTS.find((p) => p.id === 'mini-jungla')!;
const princesas = PRODUCTS.find((p) => p.id === 'castillo-de-princesas')!;
const blanco    = PRODUCTS.find((p) => p.id === 'castillo-blanco')!;
const dragones  = PRODUCTS.find((p) => p.id === 'dragones-rojos')!;
const extremo   = PRODUCTS.find((p) => p.id === 'extremo')!;

// IDs que tienen spotlight propio → se excluyen del grid para no duplicar
const SPOTLIGHT_IDS = new Set(['mini-jungla', 'castillo-de-princesas', 'castillo-blanco', 'dragones-rojos', 'extremo']);

// ── Guía de selección: qué inflable según edad y espacio (derivado de PRODUCTS) ──
const guiaRows = [
  { nivel: '1–3 años', ejemplos: 'Mini Castillo', minimo: '2×2 m (cabe en interior)', complementos: '3–4 niños' },
  { nivel: '4–10 años', ejemplos: 'Dragones Rojos · Castillo de Princesas', minimo: '4×4 m', complementos: '5–7 niños' },
  { nivel: '5–10 años', ejemplos: 'Mini Jungla · Gusanitos', minimo: '4.5×4 m / 5×3 m', complementos: '5–7 niños' },
  { nivel: '4+ años', ejemplos: 'Barco Pirata', minimo: '7×5 m (jardín amplio)', complementos: '8–10 niños' },
  { nivel: '6+ años', ejemplos: 'Circuito Extremo', minimo: '7×4 m (aire libre)', complementos: '6–10 niños' },
];

// ── Iconos inline para las tarjetas de servicio (¿por qué elegirnos?) ──
const iconSvgs: Record<string, string> = {
  truck: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`,
  shield: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  eye: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>`,
  'map-pin': `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
  clock: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  heart: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>`,
};
---

<PageLayout
  keywords={KEYWORDS}
  description="Renta de inflables en CDMX: castillos, toboganes y brincolines desde $800 MXN. Instalación incluida. 30 años de experiencia en Ciudad de México y Estado de México."
  schema={schema}
>
  {/* 1 · HERO — presenta la propuesta + precio + CTAs + confianza */}
  <Hero />

  {/* 2 · FRANJA DE SECCIONES — el hero presenta, la franja convierte */}
  <SectionMenu />

  {/* 3 · CONFIANZA — pilares honestos bajo el hero */}
  <TrustBar />

  {/* 4 · CATÁLOGO — los 8 inflables (cards data-driven) */}
  <section id="catalogo" class="section section--catalog">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="Catálogo completo"
        title="Inflables para renta"
        titleAccent="en CDMX y EdoMex"
        body={[
          'Todos nuestros inflables están desinfectados, revisados y listos para entrega en CDMX y zona metropolitana. Elige el modelo según el espacio que tengas y la edad de los niños.',
          '¿No sabes cuál elegir? Más abajo te dejamos una guía rápida por edad y espacio — o escríbenos por WhatsApp y te ayudamos a decidir en minutos.',
        ]}
      />
      <div class="catalog-grid">
        {PRODUCTS.filter((p) => !SPOTLIGHT_IDS.has(p.id)).map((p, i) => (
          <ProductCard product={p} eager={i === 0} />
        ))}
      </div>
    </div>
  </section>

  {/* 5 · SPOTLIGHT — el más pequeño (Mini Castillo). Galería a la derecha. */}
  <CategoryFeature
    eyebrow="El más pequeño"
    title="Mini Castillo:"
    titleAccent="para los más pequeños"
    description={mini.descLong}
    features={[
      { label: 'Paredes acolchadas de baja altura', desc: 'seguridad total para bebés de 1 a 3 años' },
      { label: 'Compacto 2×2 m', desc: 'cabe en interiores, departamentos y jardines pequeños' },
      { label: 'Para 4–5 bebés de 1 a 3 años', desc: 'el inflable más adecuado para los más pequeños' },
      { label: 'Llega desinfectado', desc: 'instalación incluida en CDMX y Estado de México' },
    ]}
    brands={[
      { name: 'Cumpleaños 1, 2 y 3' },
      { name: 'Baby shower' },
      { name: 'Reuniones familiares' },
    ]}
    ctaLabel="Reservar Mini Castillo"
    ctaHref={waUrl(WA_MESSAGES.reservar(mini.name))}
    ctaExternal={true}
    imgMain={{ src: mini.images[0], alt: 'Mini Castillo — inflable para bebés en renta CDMX' }}
    imgA={{ src: mini.images[1], alt: 'Mini Castillo vista lateral con paredes acolchadas' }}
    imgB={{ src: mini.images[2], alt: 'Bebés jugando en el Mini Castillo inflable' }}
  />

  {/* 6 · SPOTLIGHT — aventura temática (Mini Jungla). */}
  <CategoryFeature
    surface={true}
    eyebrow="Aventura temática"
    title="Mini Jungla:"
    titleAccent="la selva en tu fiesta"
    description={jungla.descLong}
    features={[
      { label: 'Temática selva con animales y lianas', desc: 'zonas para esconderse — más circuito que brincolin' },
      { label: 'Interior 4.5×4 m con techo cubierto', desc: 'ventilado y con sombra para 5–7 niños de 5 a 10 años' },
      { label: 'Perfecto para exploradores', desc: 'animales, safari, dinosaurios y naturaleza' },
      { label: 'Instalación incluida', desc: 'entrega y recolección en CDMX y EdoMex' },
    ]}
    brands={[
      { name: 'Fiestas temáticas' },
      { name: 'Cumpleaños 3–8 años' },
      { name: 'Kermeses escolares' },
    ]}
    ctaLabel="Reservar Mini Jungla"
    ctaHref={waUrl(WA_MESSAGES.reservar(jungla.name))}
    ctaExternal={true}
    imgMain={{ src: jungla.images[0], alt: 'Mini Jungla — inflable temático de selva en renta CDMX' }}
    imgA={{ src: jungla.images[1], alt: 'Mini Jungla detalle serpientes y animales' }}
    imgB={{ src: jungla.images[2], alt: 'Niños jugando en el inflable Mini Jungla' }}
  />

  {/* 7 · SPOTLIGHT — favorito de niñas (Castillo de Princesas). */}
  <CategoryFeature
    eyebrow="Favorito de niñas"
    title="Castillo de Princesas:"
    titleAccent="un palacio en tu jardín"
    description={princesas.descLong}
    features={[
      { label: 'Colores rosa y pastel con resbaladilla', desc: 'torres, arcos y coronas de cuento incluidas' },
      { label: 'Espacio 4×4 m para 5–7 niñas', desc: '3 a 10 años — el rango más solicitado para niñas' },
      { label: 'Espectacular para fotos', desc: 'el fondo perfecto que combina con cualquier decoración' },
      { label: 'Incluye traslado y montaje', desc: 'listo en CDMX y zona metropolitana' },
    ]}
    brands={[
      { name: 'Cumpleaños de niñas' },
      { name: 'Fiestas de princesas' },
      { name: 'Celebraciones de cuento' },
    ]}
    ctaLabel="Reservar Castillo de Princesas"
    ctaHref={waUrl(WA_MESSAGES.reservar(princesas.name))}
    ctaExternal={true}
    imgMain={{ src: princesas.images[0], alt: 'Castillo de Princesas — inflable rosa y morado en renta CDMX' }}
    imgA={{ src: princesas.images[1], alt: 'Castillo de Princesas torres y coronas de cuento' }}
    imgB={{ src: princesas.images[2], alt: 'Niñas jugando en el Castillo de Princesas' }}
  />

  {/* 8 · SPOTLIGHT — línea premium (Castillo Blanco). */}
  <CategoryFeature
    surface={true}
    eyebrow="Línea premium"
    title="Castillo Blanco:"
    titleAccent="elegancia para tu evento"
    description={blanco.descLong}
    features={[
      { label: 'Diseño blanco sin colores estridentes', desc: 'combina con cualquier paleta y ambientación' },
      { label: '6×5 m para 8–12 niños', desc: 'la zona de brinco más amplia de la línea premium' },
      { label: 'Espectacular en fotografías', desc: 'el fondo perfecto para fotos de recuerdo' },
      { label: 'Instalación y desinfección incluidas', desc: 'servicio completo en CDMX y EdoMex' },
    ]}
    brands={[
      { name: 'Bodas y XV años' },
      { name: 'Comuniones' },
      { name: 'Eventos sofisticados' },
    ]}
    ctaLabel="Reservar Castillo Blanco"
    ctaHref={waUrl(WA_MESSAGES.reservar(blanco.name))}
    ctaExternal={true}
    imgMain={{ src: blanco.images[0], alt: 'Castillo Blanco — inflable premium blanco con detalles plateados en renta CDMX' }}
    imgA={{ src: blanco.images[1], alt: 'Castillo Blanco detalle detalles plateados' }}
    imgB={{ src: blanco.images[2], alt: 'Castillo Blanco montado en jardín para evento' }}
  />

  {/* 9 · SPOTLIGHT — el más rentado (Dragones Rojos). Galería a la derecha. */}
  <CategoryFeature
    eyebrow="El más rentado"
    title="Dragones Rojos:"
    titleAccent="el favorito de las fiestas"
    description={dragones.descLong}
    features={[
      { label: 'Dos dragones de 3 m a los costados', desc: 'el inflable más llamativo de cualquier patio' },
      { label: 'Área de brinco 4×4 m', desc: 'espacio para 5–7 niños de 4 a 10 años' },
      { label: 'Funciona para niñas y niños', desc: 'combina con cualquier decoración al no ser personaje de franquicia' },
      { label: 'Necesita 5×5 m con 5 m altura libre', desc: 'preferentemente en exterior' },
    ]}
    brands={[
      { name: 'Cumpleaños 4–10' },
      { name: 'Fiestas temáticas' },
      { name: 'Eventos escolares' },
    ]}
    ctaLabel="Reservar Dragones Rojos"
    ctaHref={waUrl(WA_MESSAGES.reservar(dragones.name))}
    ctaExternal={true}
    imgMain={{ src: dragones.images[0], alt: 'Dragones Rojos — castillo inflable con dos dragones en renta en CDMX' }}
    imgA={{ src: dragones.images[1], alt: 'Dragones Rojos vista lateral con tobogán' }}
    imgB={{ src: dragones.images[2], alt: 'Niños jugando en el inflable Dragones Rojos' }}
  />

  {/* 10 · SPOTLIGHT — el más grande (Circuito Extremo). MISMO acomodo que arriba
       (galería a la derecha, SIN flip → sin zig-zag); fondo surface solo separa. */}
  <CategoryFeature
    eyebrow="El más grande"
    title="Circuito Extremo:"
    titleAccent="diversión sin límites"
    description={extremo.descLong}
    features={[
      { label: 'Muros de escalada + túneles + resbaladilla', desc: 'circuito completo de obstáculos de 7×4 m' },
      { label: 'Hasta 6–10 participantes de 6+ años', desc: 'el reto favorito para niños grandes y teams' },
      { label: 'Perfecto para competencias por equipos', desc: 'kermeses, eventos escolares y corporativos' },
      { label: 'Requiere 7×4 m al aire libre', desc: 'espacio abierto sin techo para instalación segura' },
    ]}
    brands={[
      { name: 'Eventos escolares' },
      { name: 'Fiestas +20 niños' },
      { name: 'Cumpleaños 6–15' },
    ]}
    ctaLabel="Reservar Circuito Extremo"
    ctaHref={waUrl(WA_MESSAGES.reservar(extremo.name))}
    ctaExternal={true}
    imgMain={{ src: extremo.images[0], alt: 'Circuito Extremo — inflable grande de obstáculos en renta en CDMX' }}
    imgA={{ src: extremo.images[1], alt: 'Circuito Extremo zona de escalada' }}
    imgB={{ src: extremo.images[2], alt: 'Circuito Extremo tobogán de altura' }}
  />

  {/* 7 · GUÍA DE SELECCIÓN — qué inflable según edad y espacio */}
  <RiskGuide
    eyebrow="Guía de selección"
    title="¿Cuál inflable elijo"
    titleAccent="para mi fiesta?"
    desc="Una tabla rápida para acertar a la primera, según la edad de los niños y el espacio disponible."
    body={[
      'La elección correcta depende de dos cosas: cuántos años tienen los niños y cuánto espacio tienes. Esta guía cruza ambas para llevarte directo al modelo ideal.',
      '¿Tu caso está entre dos opciones o tienes un espacio especial? Mándanos la medida por WhatsApp y te confirmamos el mejor inflable para tu evento.',
    ]}
    columns={['Edad de los niños', 'Modelo ideal', 'Espacio mínimo', 'Capacidad']}
    rows={guiaRows}
    note="Medidas orientativas por modelo. Confírmanos el alto libre y el tipo de piso (pasto, cemento o interior) y ajustamos la recomendación."
    ctaLabel="Cotizar por WhatsApp"
    ctaHref={waUrl(WA_MESSAGES.cotizar)}
  />

  {/* 8 · SOBRE LA EMPRESA — confianza (qué/cómo + cifras reales) */}
  <CompanyAbout />

  {/* 9 · ¿POR QUÉ ELEGIRNOS? — beneficios reales (servicios) */}
  <section id="servicios" class="section section--services">
    <div class="container">
      <SectionHeading
        layout="duo"
        eyebrow="¿Por qué elegirnos?"
        title="Servicio profesional"
        titleAccent="en cada renta"
        body={[
          'Tres décadas de experiencia y miles de fiestas atendidas. Instalación incluida, equipos sanitizados y atención personalizada de inicio a fin — tu fiesta, sin preocupaciones.',
          'Cubrimos toda la CDMX y zona metropolitana sin costo de traslado adicional. Llegamos puntuales, montamos y recogemos todo al terminar.',
        ]}
      />
      <div class="services-grid">
        {SERVICES.map((s) => (
          <article class="svc-card">
            <div class="svc-card__icon" aria-hidden="true" set:html={iconSvgs[s.icon] ?? `<span>${s.icon[0].toUpperCase()}</span>`} />
            <div class="svc-card__content">
              <h3 class="svc-card__title">{s.title}</h3>
              <p class="svc-card__desc">{s.desc}</p>
            </div>
            <span class="svc-card__tag">{s.tag}</span>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* 10 · PROCESO — de tu mensaje a la fiesta */}
  <ProcessSteps />

  {/* 11 · RESEÑAS — prueba social real */}
  <Reviews />

  {/* 12 · COBERTURA — zonas que atendemos */}
  <Coverage />

  {/* 13 · FAQ + CONTACTO — acordeón + tarjeta WhatsApp sticky */}
  <FAQWithContact />

  {/* 14 · BLOG — guías y consejos recientes */}
  <BlogPreview
    title="Guías para tu fiesta perfecta"
    subtitle="Artículos profesionales sobre inflables, decoración y organización de fiestas infantiles en CDMX — escritos por nuestro equipo con 30 años de experiencia."
  />

  {/* 15 · CIERRE — último empujón a la conversión */}
  <CTAFinal variant="red" />
</PageLayout>

<style>
  .container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }
  .section { padding-block: var(--section-py); }
  .section--services { background: var(--c-surface); }

  /* ── Catálogo ── */
  .catalog-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--sp-6); }
  @media (max-width: 1200px) { .catalog-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px) { .catalog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .catalog-grid { grid-template-columns: 1fr; } }

  /* ── Servicios (¿por qué elegirnos?) ── */
  .services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--sp-5); }
  @media (max-width: 900px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .services-grid { grid-template-columns: 1fr; } }

  .svc-card {
    background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-xl);
    padding: var(--sp-6); display: flex; flex-direction: column; gap: var(--sp-4);
    box-shadow: var(--shadow-sm); transition: box-shadow .2s ease, transform .2s ease;
  }
  .svc-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .svc-card__icon {
    width: 52px; height: 52px; display: flex; align-items: center; justify-content: center;
    background: rgba(var(--c-primary-rgb), .1); color: var(--c-primary); border-radius: var(--radius-lg); flex-shrink: 0;
  }
  .svc-card__content { display: flex; flex-direction: column; gap: var(--sp-2); flex: 1; }
  .svc-card__title { font-family: var(--font-heading); font-size: 1.05rem; font-weight: 700; color: var(--c-ink); line-height: 1.25; margin: 0; }
  .svc-card__desc { font-size: .875rem; color: var(--c-ink-2); line-height: 1.65; margin: 0; }
  .svc-card__tag {
    align-self: flex-start; display: inline-flex; padding: .22rem .7rem;
    background: rgba(var(--c-primary-rgb), .08); color: var(--c-primary);
    font-size: .7rem; font-weight: 700; letter-spacing: .05em; text-transform: uppercase;
    border-radius: var(--radius-full); margin-top: auto;
  }
</style>
