---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/Hero.astro';
import TrustBar from '../components/TrustBar.astro';
import SectionMenu from '../components/SectionMenu.astro';
import StatsStrip from '../components/StatsStrip.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Reviews from '../components/Reviews.astro';
import Coverage from '../components/Coverage.astro';
import FAQ from '../components/FAQ.astro';
import CTAFinal from '../components/CTAFinal.astro';
import ProductCard from '../components/ProductCard.astro';
import { SITE, PRODUCTS, SERVICES, CONTACT } from '../config/site';

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": SITE.brand,
  "description": SITE.description,
  "url": SITE.url,
  "telephone": "+52" + CONTACT.phone,
  "image": SITE.url + SITE.ogImage,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ciudad de México",
    "addressRegion": "CMX",
    "addressCountry": "MX"
  },
  "areaServed": "Ciudad de México y Estado de México",
  "openingHours": "Mo-Su 08:00-20:00"
});

const iconLetters: Record<string, string> = {
  truck: 'T',
  shield: 'S',
  eye: 'E',
  'map-pin': 'M',
  clock: 'C',
  heart: 'H',
};
---

<PageLayout
  title="Renta de inflables | Inflables para fiestas | Inflables para eventos"
  description={SITE.description}
  schema={schema}
>
  <!-- 1. Hero -->
  <Hero />

  <!-- 2. TrustBar -->
  <TrustBar />

  <!-- 3. SectionMenu -->
  <SectionMenu />

  <!-- 4. Catálogo -->
  <section id="catalogo" class="section-catalog">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">Catálogo</span>
        <h2 class="section-heading">Inflables para renta en CDMX</h2>
        <p class="section-sub">
          Los mejores inflables de la ciudad, desinfectados y con instalación incluida.
        </p>
      </div>
      <div class="catalog-grid">
        {PRODUCTS.map((p, i) => (
          <ProductCard product={p} eager={i === 0} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Servicios -->
  <section id="servicios" class="section-services">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow">¿Por qué elegirnos?</span>
        <h2 class="section-heading">30 años llevando alegría a familias</h2>
      </div>
      <div class="services-grid">
        {SERVICES.map((s) => (
          <div class="service-card">
            <div class="service-icon" aria-hidden="true">
              {iconLetters[s.icon] ?? s.icon[0].toUpperCase()}
            </div>
            <div class="service-body">
              <h3 class="service-title">{s.title}</h3>
              <p class="service-desc">{s.desc}</p>
              <span class="service-tag">{s.tag}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. ProcessSteps -->
  <ProcessSteps />

  <!-- 7. Reviews -->
  <Reviews />

  <!-- 8. StatsStrip -->
  <StatsStrip />

  <!-- 9. Coverage -->
  <Coverage />

  <!-- 10. FAQ -->
  <FAQ />

  <!-- 11. CTAFinal -->
  <CTAFinal />
</PageLayout>

<style>
/* ── Shared section header ── */
.section-header {
  text-align: center;
  margin-bottom: var(--sp-8);
}

.eyebrow {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-primary);
  margin-bottom: var(--sp-2);
}

.section-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800;
  color: var(--c-ink);
  line-height: 1.2;
  margin-bottom: var(--sp-3);
}

.section-sub {
  font-size: 1rem;
  color: var(--c-muted);
  max-width: 520px;
  margin-inline: auto;
  line-height: 1.6;
}

/* ── Container ── */
.container {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
}

/* ── Catalog section ── */
.section-catalog {
  padding-block: var(--section-py);
}

.catalog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-6);
}

@media (max-width: 900px) {
  .catalog-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .catalog-grid {
    grid-template-columns: 1fr;
  }
}

/* ── Services section ── */
.section-services {
  padding-block: var(--section-py);
  background: var(--c-surface);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-5);
}

@media (max-width: 900px) {
  .services-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 560px) {
  .services-grid {
    grid-template-columns: 1fr;
  }
}

.service-card {
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  padding: var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s ease, transform 0.2s ease;
}

.service-card:hover {
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.service-icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--c-primary);
  color: var(--c-white);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 800;
  flex-shrink: 0;
}

.service-body {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.service-title {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 700;
  color: var(--c-ink);
  line-height: 1.3;
}

.service-desc {
  font-size: 0.88rem;
  color: var(--c-muted);
  line-height: 1.6;
}

.service-tag {
  display: inline-block;
  padding: 0.18rem 0.6rem;
  background: color-mix(in srgb, var(--c-primary) 10%, transparent);
  color: var(--c-primary);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  border-radius: var(--radius-md);
  width: fit-content;
}
</style>
