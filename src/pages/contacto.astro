<script>
  // Intercepta el submit del formulario y construye mensaje de WhatsApp
  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Anti-spam: si el honeypot tiene valor, ignorar
      const bot = (document.getElementById('bot-field') as HTMLInputElement | null)?.value;
      if (bot) return;

      const nombre = (document.getElementById('nombre') as HTMLInputElement)?.value.trim();
      const telefono = (document.getElementById('telefono') as HTMLInputElement)?.value.trim();
      const email = (document.getElementById('email') as HTMLInputElement)?.value.trim();
      const alcaldia = (document.getElementById('alcaldia') as HTMLSelectElement)?.value;
      const fecha = (document.getElementById('fecha') as HTMLInputElement)?.value;
      const inflable = (document.getElementById('inflable') as HTMLSelectElement)?.value;
      const mensaje = (document.getElementById('mensaje') as HTMLTextAreaElement)?.value.trim();

      // Validar campos requeridos
      if (!nombre || !telefono || !alcaldia) {
        alert('Por favor completa los campos obligatorios: Nombre, Teléfono y Alcaldía/Municipio.');
        return;
      }

      // Construir mensaje de WhatsApp
      let msg = `Hola INFLAPY, me interesa rentar un inflable para mi fiesta. 🎉\n\n`;
      msg += `*Nombre:* ${nombre}\n`;
      msg += `*Teléfono:* ${telefono}\n`;
      if (email) msg += `*Email:* ${email}\n`;
      msg += `*Alcaldía/Municipio:* ${alcaldia}\n`;
      if (fecha) {
        // Formatear fecha legible
        const [y, m, d] = fecha.split('-');
        msg += `*Fecha del evento:* ${d}/${m}/${y}\n`;
      }
      if (inflable) msg += `*Inflable de interés:* ${inflable}\n`;
      if (mensaje) msg += `\n*Mensaje:* ${mensaje}`;

      const waNumber = '525539048634'; // CONTACT.whatsapp
      const waUrl = `https://wa.me/${waNumber}?text=${encodeURIComponent(msg)}`;

      window.open(waUrl, '_blank', 'noopener,noreferrer');
    });
  }
</script>
