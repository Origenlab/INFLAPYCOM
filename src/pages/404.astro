---
import PageLayout from '../layouts/PageLayout.astro';
import { SITE, CONTACT, WA_MESSAGES } from '../config/site';
import { waUrl, telUrl } from '../lib/utils';

const waHref = waUrl(WA_MESSAGES.cotizar);
const telHref = telUrl();

const popularLinks = [
  { label: 'Mini Castillo (para bebés)', href: '/inflables-chicos/mini-castillo' },
  { label: 'Dragones Rojos', href: '/inflables-medianos/dragones-rojos' },
  { label: 'Castillo de Princesas', href: '/inflables-medianos/castillo-de-princesas' },
  { label: 'Barco Pirata', href: '/inflables-grandes/barco-pirata' },
  { label: 'Circuito Extremo', href: '/inflables-grandes/extremo' },
  { label: 'Castillo Blanco', href: '/inflables-grandes/castillo-blanco' },
];
---

<PageLayout
  title="Página no encontrada (404) | INFLAPY"
  description="Esta página no existe o fue movida. Explora nuestro catálogo de inflables para renta en CDMX."
  canonical={`${SITE.url}/404`}
>
  <section class="error-hero">
    <div class="container">
      <div class="error-inner">
        <div class="error-graphic" aria-hidden="true">
          <span class="error-number">404</span>
          <span class="error-balloon">🎈</span>
        </div>

        <div class="error-content">
          <span class="eyebrow">Página no encontrada</span>
          <h1 class="error-heading">¡Ups! Este inflable se fue volando</h1>
          <p class="error-desc">
            La página que buscas no existe o fue movida. Pero no te preocupes —
            tenemos muchos inflables esperándote.
          </p>

          <div class="error-actions">
            <a href="/" class="btn btn-primary">Ir al inicio</a>
            <a href="/catalogo" class="btn btn-secondary">Ver catálogo</a>
            <a href={waHref} class="btn btn-wa" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" width="18" height="18"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.955 7.955 0 01-4.078-1.118l-.29-.173-3.008.853.854-2.938-.19-.302A7.955 7.955 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
              Cotizar por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular links -->
  <section class="popular-section">
    <div class="container">
      <h2 class="popular-title">Inflables más rentados</h2>
      <ul class="popular-grid">
        {popularLinks.map(link => (
          <li>
            <a href={link.href} class="popular-card">
              <span class="popular-label">{link.label}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="popular-bottom">
        <a href="/articulos" class="popular-articles-link">
          Leer guías y artículos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
.container {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-px);
}

/* ── Error hero ── */
.error-hero {
  padding-block: var(--sp-16) var(--sp-12);
  background: var(--c-white);
  border-bottom: 1px solid var(--c-border);
}

.error-inner {
  display: flex;
  align-items: center;
  gap: var(--sp-12);
  flex-wrap: wrap;
}

.error-graphic {
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 220px;
  height: 180px;
}

.error-number {
  font-family: var(--font-heading);
  font-size: 9rem;
  font-weight: 900;
  line-height: 1;
  letter-spacing: -0.05em;
  color: color-mix(in srgb, var(--c-primary) 12%, transparent);
  user-select: none;
}

.error-balloon {
  position: absolute;
  top: -10px;
  right: -10px;
  font-size: 3rem;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}

.error-content {
  flex: 1;
  min-width: 260px;
}

.eyebrow {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--c-primary);
  margin-bottom: var(--sp-2);
}

.error-heading {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 3.5vw, 2.4rem);
  font-weight: 800;
  color: var(--c-ink);
  line-height: 1.15;
  margin-bottom: var(--sp-4);
  letter-spacing: -0.02em;
}

.error-desc {
  font-size: 1rem;
  color: var(--c-muted);
  line-height: 1.65;
  max-width: 480px;
  margin-bottom: var(--sp-7);
}

.error-actions {
  display: flex;
  flex-wrap: wrap;
  gap: var(--sp-3);
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  padding: 0.75rem 1.5rem;
  font-family: var(--font-heading);
  font-size: 0.875rem;
  font-weight: 600;
  border-radius: var(--radius-md);
  border: 2px solid transparent;
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
  text-decoration: none;
  line-height: 1;
}

.btn-primary {
  background: var(--c-primary);
  color: var(--c-white);
  box-shadow: 0 4px 14px rgba(var(--c-primary-rgb), 0.35);
}
.btn-primary:hover { background: var(--c-primary-dark, #6d28d9); transform: translateY(-1px); }

.btn-secondary {
  background: transparent;
  color: var(--c-ink);
  border-color: var(--c-border);
}
.btn-secondary:hover { border-color: var(--c-ink); background: var(--c-surface); }

.btn-wa {
  background: var(--c-wa);
  color: #04210f;
  box-shadow: 0 4px 14px rgba(37,211,102,.3);
}
.btn-wa:hover { background: #1ebe5a; transform: translateY(-1px); }

/* ── Popular section ── */
.popular-section {
  padding-block: var(--section-py);
  background: var(--c-surface);
}

.popular-title {
  font-family: var(--font-heading);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--c-ink);
  margin-bottom: var(--sp-6);
}

.popular-grid {
  list-style: none;
  padding: 0;
  margin: 0 0 var(--sp-8);
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-3);
}

.popular-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-3);
  padding: var(--sp-4) var(--sp-5);
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-lg);
  text-decoration: none;
  color: var(--c-ink);
  font-size: 0.9rem;
  font-weight: 500;
  transition: all 0.15s ease;
  box-shadow: var(--shadow-sm);
}
.popular-card:hover {
  border-color: var(--c-primary);
  color: var(--c-primary);
  box-shadow: var(--shadow-md);
  transform: translateY(-2px);
}

.popular-label { line-height: 1.3; }

.popular-bottom {
  text-align: center;
  padding-top: var(--sp-4);
}

.popular-articles-link {
  display: inline-flex;
  align-items: center;
  gap: var(--sp-2);
  font-family: var(--font-heading);
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--c-primary);
  text-decoration: none;
  transition: gap 0.15s ease;
}
.popular-articles-link:hover { gap: var(--sp-3); text-decoration: underline; }

@media (max-width: 900px) { .popular-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 560px) {
  .popular-grid { grid-template-columns: 1fr; }
  .error-inner { flex-direction: column; text-align: center; }
  .error-graphic { width: 160px; height: 140px; }
  .error-number { font-size: 6.5rem; }
  .error-desc { max-width: 100%; }
  .error-actions { justify-content: center; }
}
</style>
