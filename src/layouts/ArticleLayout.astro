---
// ArticleLayout.astro — Layout mejorado para artículos de blog INFLAPY
// Incluye: barra de progreso, ToC dinámica, tiempo de lectura, tags,
// compartir, artículos relacionados.
import PageLayout from './PageLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE, WA_MESSAGES } from '../config/site';
import { waUrl } from '../lib/utils';

interface RelatedPost {
  id: string;
  title: string;
  excerpt: string;
  image?: string;
  imageAlt?: string;
  date: Date;
  tags: string[];
  product?: string;
}

interface Props {
  title: string;
  excerpt: string;
  date: Date;
  product?: string;
  productSlug?: string;
  image?: string;
  imageAlt?: string;
  author?: string;
  slug: string;
  tags?: string[];
  readingTime?: number;
  relatedPosts?: RelatedPost[];
}

const {
  title,
  excerpt,
  date,
  product,
  productSlug,
  image,
  imageAlt,
  author = 'Equipo INFLAPY',
  slug,
  tags = [],
  readingTime = 5,
  relatedPosts = [],
} = Astro.props;

const waHref = waUrl(WA_MESSAGES.cotizar);
const dateStr = date.toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' });
const canonical = `${SITE.url}/articulos/${slug}`;

const PRODUCT_LABELS: Record<string, string> = {
  'mini-castillo':        'Mini Castillo',
  'dragones-rojos':       'Dragones Rojos',
  'mini-jungla':          'Mini Jungla',
  'gusanitos':            'Gusanitos',
  'castillo-de-princesas':'Castillo de Princesas',
  'barco-pirata':         'Barco Pirata',
  'extremo':              'Circuito Extremo',
  'castillo-blanco':      'Castillo Blanco',
};
const productLabel = product ? (PRODUCT_LABELS[product] ?? product) : null;

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": excerpt,
  "image": image ? `${SITE.url}${image}` : `${SITE.url}${SITE.ogImage}`,
  "datePublished": date.toISOString(),
  "author": { "@type": "Organization", "name": SITE.brand, "url": SITE.url },
  "publisher": {
    "@type": "Organization",
    "name": SITE.brand,
    "url": SITE.url,
    "logo": { "@type": "ImageObject", "url": `${SITE.url}/img/logo-inflapy.png` }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonical }
});
---

<PageLayout
  title={`${title} | INFLAPY`}
  description={excerpt}
  canonical={canonical}
  ogImage={image ? `${SITE.url}${image}` : undefined}
  schema={schema}
>
  <!-- Reading progress bar -->
  <div class="read-progress" id="read-progress" role="progressbar" aria-valuemin={0} aria-valuemax={100} aria-valuenow={0} aria-label="Progreso de lectura"></div>

  <!-- Breadcrumb -->
  <div class="breadcrumb-bar">
    <div class="container">
      <Breadcrumbs items={[
        { label: 'Inicio', href: '/' },
        { label: 'Artículos', href: '/articulos' },
        { label: title },
      ]} />
    </div>
  </div>

  <div class="article-wrap">
    <div class="container article-container">

      <!-- ── Main article ─────────────────────────── -->
      <article class="article" itemscope itemtype="https://schema.org/Article">

        <!-- Hero image -->
        {image && (
          <figure class="article-hero">
            <img
              src={image}
              alt={imageAlt ?? title}
              width="1200" height="630"
              loading="eager" decoding="auto" fetchpriority="high"
              itemprop="image"
              onerror="this.src='/img/placeholder.svg'"
            />
          </figure>
        )}

        <!-- Header -->
        <header class="article-header">
          <div class="article-meta-row">
            {productLabel && (
              <span class="product-badge">{productLabel}</span>
            )}
            <div class="article-meta">
              <time datetime={date.toISOString()} itemprop="datePublished">{dateStr}</time>
              <span class="meta-dot" aria-hidden="true">·</span>
              <span class="meta-rt">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                {readingTime} min de lectura
              </span>
              <span class="meta-dot" aria-hidden="true">·</span>
              <span itemprop="author">{author}</span>
            </div>
          </div>

          <h1 class="article-title" itemprop="headline">{title}</h1>
          <p class="article-excerpt">{excerpt}</p>

          {tags.length > 0 && (
            <div class="article-tags" aria-label="Etiquetas">
              {tags.map(t => <span class="tag-chip">{t}</span>)}
            </div>
          )}
        </header>

        <!-- Content -->
        <div class="article-body prose" itemprop="articleBody" id="article-body">
          <slot />
        </div>

        <!-- Share row -->
        <div class="article-share">
          <span class="share-label">Compartir:</span>
          <a
            href={`https://wa.me/?text=${encodeURIComponent(title + ' ' + canonical)}`}
            class="share-btn share-btn--wa"
            target="_blank" rel="noopener noreferrer"
            aria-label="Compartir en WhatsApp"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.955 7.955 0 01-4.078-1.118l-.29-.173-3.008.853.854-2.938-.19-.302A7.955 7.955 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
            WhatsApp
          </a>
          <button class="share-btn share-btn--copy" id="copy-link-btn" aria-label="Copiar enlace">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
            <span id="copy-label">Copiar enlace</span>
          </button>
        </div>

        <!-- CTA inline -->
        <div class="article-cta-box">
          <div class="cta-box-inner">
            <div class="cta-box-text">
              <p class="cta-box-title">¿Listo para reservar tu inflable?</p>
              <p class="cta-box-desc">Cotiza en minutos por WhatsApp — respondemos rápido y separamos tu fecha sin compromiso.</p>
            </div>
            <div class="cta-box-btns">
              <a href={waHref} class="btn-wa" target="_blank" rel="noopener noreferrer">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.955 7.955 0 01-4.078-1.118l-.29-.173-3.008.853.854-2.938-.19-.302A7.955 7.955 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
                Cotizar por WhatsApp
              </a>
              {productSlug && (
                <a href={`/${productSlug}`} class="btn-outline">
                  Ver ficha del inflable
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              )}
            </div>
          </div>
        </div>

        <!-- Related articles -->
        {relatedPosts.length > 0 && (
          <div class="article-related">
            <h2 class="related-heading">También te puede interesar</h2>
            <div class="related-grid">
              {relatedPosts.map(rp => {
                const rDate = rp.date.toLocaleDateString('es-MX', { year: 'numeric', month: 'short', day: 'numeric' });
                return (
                  <article class="related-card">
                    {rp.image && (
                      <a href={`/articulos/${rp.id}`} class="related-img" tabindex="-1">
                        <img src={rp.image} alt={rp.imageAlt ?? rp.title} width="400" height="225" loading="lazy" decoding="async" onerror="this.src='/img/placeholder.svg'" />
                      </a>
                    )}
                    <div class="related-body">
                      <time class="related-date">{rDate}</time>
                      <h3 class="related-title">
                        <a href={`/articulos/${rp.id}`}>{rp.title}</a>
                      </h3>
                      <p class="related-excerpt">{rp.excerpt}</p>
                    </div>
                  </article>
                );
              })}
            </div>
          </div>
        )}

        <!-- Volver -->
        <footer class="article-footer">
          <a href="/articulos" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Ver todos los artículos
          </a>
        </footer>
      </article>

      <!-- ── Sidebar ────────────────────────────────── -->
      <aside class="article-sidebar">

        <!-- CTA card -->
        <div class="sidebar-card sidebar-card--cta">
          <p class="sidebar-card__icon" aria-hidden="true">🎈</p>
          <p class="sidebar-card__title">¿Tienes una fiesta próxima?</p>
          <p class="sidebar-card__desc">Cotiza tu inflable en minutos. Instalación incluida en CDMX y EdoMex.</p>
          <a href={waHref} class="sidebar-wa-btn" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.978-1.41A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a7.955 7.955 0 01-4.078-1.118l-.29-.173-3.008.853.854-2.938-.19-.302A7.955 7.955 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
            Cotizar ahora
          </a>
        </div>

        <!-- ToC -->
        <div class="sidebar-card sidebar-toc-card" id="toc-card" aria-label="Tabla de contenidos">
          <p class="sidebar-card__title">En este artículo</p>
          <nav id="toc" aria-label="Índice del artículo"></nav>
        </div>

        <!-- Links catálogo -->
        <div class="sidebar-card sidebar-card--links">
          <p class="sidebar-card__title">Nuestros inflables</p>
          <ul class="sidebar-links">
            <li><a href="/inflables-chicos/mini-castillo">Mini Castillo</a></li>
            <li><a href="/inflables-medianos/dragones-rojos">Dragones Rojos</a></li>
            <li><a href="/inflables-medianos/mini-jungla">Mini Jungla</a></li>
            <li><a href="/inflables-medianos/gusanitos">Gusanitos</a></li>
            <li><a href="/inflables-medianos/castillo-de-princesas">Castillo de Princesas</a></li>
            <li><a href="/inflables-grandes/barco-pirata">Barco Pirata</a></li>
            <li><a href="/inflables-grandes/extremo">Circuito Extremo</a></li>
            <li><a href="/inflables-grandes/castillo-blanco">Castillo Blanco</a></li>
          </ul>
          <a href="/catalogo" class="sidebar-catalog-link">Ver catálogo completo →</a>
        </div>

      </aside>
    </div>
  </div>
</PageLayout>

<script>
  // ── Reading progress bar ───────────────────────────
  const progressBar = document.getElementById('read-progress');
  if (progressBar) {
    const update = () => {
      const scrolled = window.scrollY;
      const total = document.documentElement.scrollHeight - window.innerHeight;
      const pct = total > 0 ? Math.min(100, (scrolled / total) * 100) : 0;
      progressBar.style.width = `${pct}%`;
      progressBar.setAttribute('aria-valuenow', String(Math.round(pct)));
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  // ── Table of Contents (auto from h2s) ─────────────
  const body = document.getElementById('article-body');
  const toc  = document.getElementById('toc');
  const tocCard = document.getElementById('toc-card');

  if (body && toc) {
    const headings = Array.from(body.querySelectorAll('h2'));

    if (headings.length >= 2) {
      const ul = document.createElement('ul');
      ul.className = 'toc-list';

      headings.forEach((h, i) => {
        if (!h.id) h.id = `section-${i}`;
        const li = document.createElement('li');
        li.className = 'toc-item';
        const a = document.createElement('a');
        a.href = `#${h.id}`;
        a.textContent = h.textContent ?? '';
        a.className = 'toc-link';
        li.appendChild(a);
        ul.appendChild(li);
      });

      toc.appendChild(ul);

      // Highlight active section on scroll
      const observer = new IntersectionObserver(
        entries => {
          entries.forEach(entry => {
            const id = entry.target.id;
            const link = toc.querySelector<HTMLAnchorElement>(`a[href="#${id}"]`);
            if (link) {
              if (entry.isIntersecting) {
                toc.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
                link.classList.add('active');
              }
            }
          });
        },
        { rootMargin: '-80px 0px -60% 0px' }
      );

      headings.forEach(h => observer.observe(h));
    } else {
      // Hide ToC card if fewer than 2 sections
      if (tocCard) tocCard.style.display = 'none';
    }
  }

  // ── Copy link ─────────────────────────────────────
  const copyBtn = document.getElementById('copy-link-btn');
  const copyLabel = document.getElementById('copy-label');
  if (copyBtn && copyLabel) {
    copyBtn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        copyLabel.textContent = '¡Copiado!';
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyLabel.textContent = 'Copiar enlace';
          copyBtn.classList.remove('copied');
        }, 2000);
      } catch {
        copyLabel.textContent = 'Error al copiar';
      }
    });
  }
</script>

<style>
/* ── Progress bar ── */
.read-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 0%;
  height: 3px;
  background: linear-gradient(90deg, var(--c-primary) 0%, #9b59f5 100%);
  z-index: 9999;
  transition: width 0.1s linear;
  border-radius: 0 2px 2px 0;
}

/* ── Layout ── */
.breadcrumb-bar { background: var(--c-white); border-bottom: 1px solid var(--c-border); padding-block: var(--sp-3); }
.container { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }

.article-wrap { background: var(--c-surface); padding-block: var(--sp-10) var(--section-py); }

.article-container {
  display: grid;
  grid-template-columns: 1fr 300px;
  gap: var(--sp-8);
  align-items: start;
}

/* ── Article card ── */
.article {
  background: var(--c-white);
  border: 1px solid var(--c-border);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.article-hero { margin: 0; aspect-ratio: 16 / 9; overflow: hidden; background: var(--c-surface); }
.article-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Header ── */
.article-header {
  padding: var(--sp-7) var(--sp-8) var(--sp-6);
  border-bottom: 1px solid var(--c-border);
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
}

.article-meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--sp-3);
}
.product-badge {
  display: inline-block;
  font-family: var(--font-heading);
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  color: var(--c-primary);
  background: rgba(var(--c-primary-rgb), 0.1);
  padding: 0.3rem 0.8rem;
  border-radius: var(--radius-full);
}
.article-meta {
  display: flex;
  align-items: center;
  gap: var(--sp-2);
  font-size: 0.8rem;
  color: var(--c-muted);
  font-weight: 500;
  flex-wrap: wrap;
}
.meta-dot { opacity: 0.4; }
.meta-rt { display: inline-flex; align-items: center; gap: 4px; }

.article-title {
  font-family: var(--font-heading);
  font-size: clamp(1.4rem, 2.8vw, 2rem);
  font-weight: 800;
  color: var(--c-ink);
  line-height: 1.2;
  letter-spacing: -0.025em;
  margin: 0;
}
.article-excerpt {
  font-size: 1.05rem;
  color: var(--c-ink-2);
  line-height: 1.7;
  margin: 0;
  border-left: 3px solid var(--c-primary);
  padding-left: var(--sp-4);
}
.article-tags { display: flex; flex-wrap: wrap; gap: var(--sp-2); }
.tag-chip {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 500;
  color: var(--c-muted);
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  padding: 0.22rem 0.65rem;
  border-radius: var(--radius-full);
}

/* ── Prose ── */
.article-body { padding: var(--sp-8); }

.prose :global(h2) {
  font-family: var(--font-heading);
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--c-ink);
  margin: var(--sp-10) 0 var(--sp-4);
  padding-bottom: var(--sp-3);
  border-bottom: 2px solid var(--c-border);
  letter-spacing: -0.015em;
  scroll-margin-top: 90px;
}
.prose :global(h2:first-child) { margin-top: 0; }
.prose :global(h3) {
  font-family: var(--font-heading);
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--c-ink);
  margin: var(--sp-7) 0 var(--sp-3);
  scroll-margin-top: 80px;
}
.prose :global(p) {
  font-size: 1rem;
  color: var(--c-ink-2);
  line-height: 1.85;
  margin: 0 0 var(--sp-5);
}
.prose :global(ul), .prose :global(ol) {
  padding-left: var(--sp-6);
  margin: 0 0 var(--sp-6);
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}
.prose :global(li) {
  font-size: 0.97rem;
  color: var(--c-ink-2);
  line-height: 1.7;
}
.prose :global(li::marker) { color: var(--c-primary); font-weight: 700; }
.prose :global(strong) { color: var(--c-ink); font-weight: 700; }
.prose :global(em) { font-style: italic; color: var(--c-ink); }
.prose :global(a) { color: var(--c-primary); text-decoration: underline; }
.prose :global(hr) {
  border: none;
  border-top: 2px solid var(--c-border);
  margin: var(--sp-8) 0;
}

/* Tables */
.prose :global(table) {
  width: 100%;
  border-collapse: collapse;
  margin: var(--sp-7) 0;
  font-size: 0.875rem;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid var(--c-border);
  box-shadow: var(--shadow-sm);
}
.prose :global(thead) { background: var(--c-primary); color: #fff; }
.prose :global(th) {
  padding: var(--sp-3) var(--sp-4);
  text-align: left;
  font-family: var(--font-heading);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.prose :global(td) {
  padding: var(--sp-3) var(--sp-4);
  border-bottom: 1px solid var(--c-border);
  color: var(--c-ink-2);
  vertical-align: top;
